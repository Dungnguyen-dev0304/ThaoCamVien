@model IEnumerable<SharedThaoCamVien.Models.Poi>
@{
    Layout = "_adminlayout";
    var translationCounts = ViewBag.TranslationCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<style>
    .bg-custom-primary { background-color: #89d957; }
    .bg-gradient-custom { background: linear-gradient(90deg, #89d957 10%, #c9e265 100%); }
    .table-row-hover:hover {
        background-color: #f8fafc;
        transform: translateY(-1px);
        transition: all 0.2s ease;
    }
</style>

<div class="p-6">
    <div class="max-w-full mx-auto">

        @* HEADER *@
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
                <h2 class="text-2xl font-black text-slate-800 uppercase tracking-tight">
                    Quản lý bản dịch
                </h2>
                <p class="text-slate-500 mt-1">
                    Tổng cộng <span class="font-bold text-custom-primary">@Model.Count()</span> địa điểm có thể thêm bản dịch
                </p>
            </div>
        </div>

        @* BẢNG *@
        <div class="bg-white rounded-[32px] shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50">
                            <th class="px-8 py-5 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Địa điểm</th>
                            <th class="px-6 py-5 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Danh mục</th>
                            <th class="px-6 py-5 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 text-center">Số bản dịch</th>
                            <th class="px-8 py-5 text-[11px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-8 py-20 text-center">
                                    <div class="inline-flex items-center justify-center w-20 h-20 bg-slate-50 rounded-full mb-4">
                                        <span class="text-4xl">🌐</span>
                                    </div>
                                    <p class="text-slate-400 font-bold uppercase text-xs tracking-widest">
                                        Chưa có địa điểm nào để dịch
                                    </p>
                                </td>
                            </tr>
                        }

                        @foreach (var item in Model)
                        {
                            var count = translationCounts.ContainsKey(item.PoiId) ? translationCounts[item.PoiId] : 0;

                            <tr class="table-row-hover transition-all">
                                <td class="px-8 py-5">
                                    <div class="flex items-center gap-4">
                                        @if (!string.IsNullOrEmpty(item.ImageThumbnail))
                                        {
                                            <img src="/images/pois/@item.ImageThumbnail" class="w-14 h-14 rounded-2xl object-cover shadow-sm border border-slate-100 flex-shrink-0" />
                                        }
                                        else
                                        {
                                            <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center flex-shrink-0 border border-slate-100">
                                                <i class="bi bi-image text-slate-300 text-2xl"></i>
                                            </div>
                                        }
                                        <div>
                                            <div class="font-black text-slate-700 text-sm uppercase">@item.Name</div>
                                            <div class="text-[10px] text-slate-400 font-mono mt-0.5">ID: #@item.PoiId</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5">
                                    <span class="px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-wider
                                        @(item.CategoryId == 1 ? "bg-orange-50 text-orange-600 border border-orange-100" :
                                                                                    item.CategoryId == 2 ? "bg-green-50 text-green-600 border border-green-100" :
                                                                                                           "bg-purple-50 text-purple-600 border border-purple-100")">
                                        @(item.CategoryId == 1 ? "Động vật" : item.CategoryId == 2 ? "Thực vật" : "Di tích")
                                    </span>
                                </td>
                                <td class="px-6 py-5 text-center">
                                    @if (count > 0)
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-green-50 text-green-600 border border-green-100 rounded-full text-[11px] font-black">
                                            <i class="bi bi-check-circle-fill text-xs"></i>
                                            @count bản dịch
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-50 text-slate-400 border border-slate-100 rounded-full text-[11px] font-black">
                                            <i class="bi bi-dash-circle text-xs"></i>
                                            Chưa có
                                        </span>
                                    }
                                </td>
                                <td class="px-8 py-5 text-right">
                                    <a href="/Translation/EditTranslations/@item.PoiId"
                                           class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-600 rounded-xl hover:bg-blue-600 hover:text-white transition-all shadow-sm text-xs font-black uppercase tracking-wide">
                                        <i class="bi bi-translate"></i>
                                        Quản lý bản dịch
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
