@model IEnumerable<SharedThaoCamVien.Models.Poi>
@{
    Layout = "_adminlayout";
    var audioMap = ViewBag.AudioMap as Dictionary<int, Dictionary<string, SharedThaoCamVien.Models.PoiAudio>>;
    var langs = ViewBag.SupportedLangs as string[];
}

<style>
    .bg-gradient-custom { background: linear-gradient(90deg, #89d957 10%, #c9e265 100%); }
    .bg-custom-primary  { background-color: #89d957; }

    .lang-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px; border-radius: 8px;
        font-size: 10px; font-weight: 900; letter-spacing: .04em;
        text-transform: uppercase;
    }
    .lang-badge.has-audio  { background: #dcfce7; color: #166534; border: 1.5px solid #86efac; }
    .lang-badge.no-audio   { background: #f1f5f9; color: #94a3b8; border: 1.5px dashed #cbd5e1; }

    .poi-row:hover { background: #f8fafc; }
</style>

<div class="p-6">
    <div class="max-w-6xl mx-auto">

        @* HEADER *@
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
            <div>
                <h2 class="text-2xl font-black text-slate-800 uppercase tracking-tight flex items-center gap-3">
                    <span class="w-10 h-10 bg-custom-primary text-white rounded-xl flex items-center justify-center">
                        <i class="bi bi-mic-fill"></i>
                    </span>
                    Quản lý Audio
                </h2>
                <p class="text-slate-500 text-sm mt-1">Thuyết minh audio cho từng địa điểm theo ngôn ngữ</p>
            </div>
        </div>

        @* THÔNG BÁO *@
        @if (TempData["Success"] != null)
        {
            <div class="mb-6 flex items-center gap-3 px-5 py-4 bg-green-50 border border-green-100 rounded-2xl text-green-700 text-sm font-semibold">
                <i class="bi bi-check-circle-fill text-green-500"></i> @TempData["Success"]
            </div>
        }

        @* BẢNG THỐNG KÊ *@
        <div class="bg-white rounded-[28px] border border-slate-100 shadow-sm overflow-hidden">

            @* HEADER ROW *@
            <div class="grid gap-4 px-6 py-4 bg-slate-50 border-b border-slate-100 text-[10px] font-black text-slate-400 uppercase tracking-widest"
                 style="grid-template-columns: 60px 1fr auto auto">
                <span>Ảnh</span>
                <span>Địa điểm</span>
                <span class="text-center">Ngôn ngữ có audio</span>
                <span class="text-center">Thao tác</span>
            </div>

            @if (!Model.Any())
            {
                <div class="py-20 text-center text-slate-400 text-sm font-bold uppercase tracking-widest">
                    Chưa có địa điểm nào
                </div>
            }
            else
            {
                @foreach (var poi in Model)
                {
                    var poiAudios = audioMap != null && audioMap.ContainsKey(poi.PoiId)
                        ? audioMap[poi.PoiId]
                        : new Dictionary<string, SharedThaoCamVien.Models.PoiAudio>();

                    int hasCount = poiAudios.Count;
                    int totalCount = langs?.Length ?? 0;

                    <div class="poi-row grid gap-4 items-center px-6 py-4 border-b border-slate-50 transition-colors"
                         style="grid-template-columns: 60px 1fr auto auto">

                        @* ẢNH *@
                        <div>
                            @if (!string.IsNullOrEmpty(poi.ImageThumbnail))
                            {
                                <img src="/images/pois/@poi.ImageThumbnail"
                                     class="w-12 h-12 rounded-xl object-cover shadow-sm" />
                            }
                            else
                            {
                                <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-xl">🌿</div>
                            }
                        </div>

                        @* TÊN + INFO *@
                        <div>
                            <p class="font-black text-slate-700 text-sm">@poi.Name</p>
                            <p class="text-[11px] text-slate-400 mt-0.5">
                                ID #@poi.PoiId &nbsp;·&nbsp;
                                <span class="@(poi.CategoryId == 1 ? "text-orange-500" : poi.CategoryId == 2 ? "text-green-500" : "text-purple-500") font-bold">
                                    @(poi.CategoryId == 1 ? "Động vật" : poi.CategoryId == 2 ? "Thực vật" : "Di tích")
                                </span>
                            </p>
                        </div>

                        @* BADGE NGÔN NGỮ *@
                        <div class="flex items-center gap-1.5 flex-wrap justify-center">
                            @if (langs != null)
                            {
                                @foreach (var lang in langs)
                                {
                                    bool has = poiAudios.ContainsKey(lang);
                                    <span class="lang-badge @(has ? "has-audio" : "no-audio")"
                                          title="@lang.ToUpper() — @(has ? "Đã có audio" : "Chưa có audio")">
                                        @lang.ToUpper()
                                    </span>
                                }
                            }
                            <span class="ml-2 text-[10px] text-slate-400 font-bold">@hasCount/@totalCount</span>
                        </div>

                        @* NÚT QUẢN LÝ *@
                        <div>
                            <a href="/Audio/Manage/@poi.PoiId"
                                   class="inline-flex items-center gap-2 px-4 py-2 bg-custom-primary text-white font-black rounded-xl text-[11px] uppercase tracking-widest hover:opacity-90 transition-opacity shadow-sm shadow-[#89d957]/30">
                                <i class="bi bi-music-note-beamed"></i>
                                Quản lý
                            </a>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>
