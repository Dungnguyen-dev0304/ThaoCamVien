@model WebThaoCamVien.ViewModels.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập | Thảo Cầm Viên Sài Gòn</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .bg-gradient-zoo {
            background: linear-gradient(135deg, #89d957 0%, #c9e265 100%);
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
        }

        .input-focus:focus {
            box-shadow: 0 0 0 4px rgba(137, 217, 87, 0.15);
        }
        /* Hiệu ứng trang trí nền */
        .shape-blob {
            background: #89d957;
            height: 400px;
            width: 400px;
            border-radius: 40% 50% 30% 40%;
            animation: transform 20s ease-in-out infinite both alternate, appearance 1s forwards;
            opacity: 0.1;
            position: fixed;
            z-index: -1;
        }

        @@keyframes transform {
            0%, 100% {
                border-radius: 33% 67% 70% 30% / 30% 30% 70% 70%;
            }

            20% {
                border-radius: 37% 63% 51% 49% / 37% 65% 35% 63%;
            }

            40% {
                border-radius: 36% 64% 64% 36% / 64% 48% 52% 36%;
            }

            60% {
                border-radius: 37% 63% 51% 49% / 30% 30% 70% 70%;
            }

            80% {
                border-radius: 40% 60% 42% 58% / 41% 51% 49% 59%;
            }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen flex items-center justify-center p-6 relative overflow-hidden">

    <div class="shape-blob -top-20 -left-20"></div>
    <div class="shape-blob -bottom-20 -right-20" style="background: #c9e265;"></div>

    <div class="w-full max-w-[450px] z-10">
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-gradient-zoo text-white rounded-[32px] shadow-2xl shadow-[#89d957]/40 mb-6 transition-transform hover:scale-105 duration-300">
                <i class="bi bi-tree-fill text-5xl"></i>
            </div>
            <h1 class="text-3xl font-extrabold text-slate-800 uppercase tracking-tighter">
                Thảo Cầm Viên <span class="text-[#89d957]">Sài Gòn</span>
            </h1>
            <p class="text-slate-400 font-medium mt-2">Hệ thống quản lý nội bộ dành cho Quản trị viên</p>
        </div>

        <div class="glass-card p-10 rounded-[40px] shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-white relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-zoo"></div>

            <form asp-controller="Account" asp-action="Login" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                @if (ViewBag.Error != null)
                {
                    <div class="bg-red-50 border border-red-100 text-red-500 p-4 rounded-2xl text-xs font-bold flex items-center gap-3 animate-pulse">
                        <i class="bi bi-shield-exclamation text-xl"></i>
                        @ViewBag.Error
                    </div>
                }

                <div class="space-y-2">
                    <label class="block text-[11px] font-black text-slate-400 uppercase tracking-[0.15em] ml-2">Địa chỉ Email</label>
                    <div class="relative group">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-[#89d957] transition-colors">
                            <i class="bi bi-envelope-at text-xl"></i>
                        </div>
                        <input type="email" name="email" required
                               class="w-full pl-12 pr-6 py-4 rounded-2xl bg-slate-100/50 border-2 border-transparent focus:bg-white focus:border-[#89d957]/30 outline-none transition-all font-semibold text-slate-700 placeholder:text-slate-300 input-focus"
                               placeholder="example@gmail.com">
                    </div>
                </div>

                <div class="space-y-2">
                    <div class="flex justify-between items-center px-2">
                        <label class="block text-[11px] font-black text-slate-400 uppercase tracking-[0.15em]">Mật khẩu</label>
                        <a href="#" class="text-[10px] text-[#89d957] font-bold hover:underline uppercase tracking-tighter">Quên mật khẩu?</a>
                    </div>
                    <div class="relative group">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-[#89d957] transition-colors">
                            <i class="bi bi-shield-lock text-xl"></i>
                        </div>
                        <input type="password" name="password" id="passwordInput" required
                               class="w-full pl-12 pr-14 py-4 rounded-2xl bg-slate-100/50 border-2 border-transparent focus:bg-white focus:border-[#89d957]/30 outline-none transition-all font-semibold text-slate-700 placeholder:text-slate-300 input-focus"
                               placeholder="••••••••">
                        <button type="button" onclick="togglePassword()" class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-300 hover:text-slate-500 transition-colors">
                            <i id="toggleIcon" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="flex items-center gap-3 px-2">
                    <input type="checkbox" id="remember" class="w-5 h-5 rounded-lg border-slate-200 text-[#89d957] focus:ring-[#89d957] transition-all cursor-pointer">
                    <label for="remember" class="text-sm text-slate-500 font-medium cursor-pointer select-none">Duy trì đăng nhập</label>
                </div>

                <button type="submit"
                        class="w-full py-5 bg-gradient-zoo text-white font-black rounded-2xl shadow-xl shadow-[#89d957]/30 uppercase tracking-widest text-sm mt-4 hover:scale-[1.02] hover:shadow-[#89d957]/40 active:scale-95 transition-all duration-300">
                    Đăng nhập hệ thống
                </button>
            </form>
        </div>

        <div class="mt-12 text-center">
            <p class="text-slate-300 text-[10px] font-black uppercase tracking-[0.3em]">
                &copy; 2026 Thao Cam Vien CMS Management
            </p>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('toggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }
    </script>
</body>
</html>