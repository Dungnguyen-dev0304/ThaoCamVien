<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewData["Title"] ?? "Thảo Cầm Viên") - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .bg-custom-primary { background-color: #89d957; }
        .text-custom-primary { color: #89d957; }
        .bg-gradient-custom { background: linear-gradient(90deg, #89d957 10%, #c9e265 100%); }

        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }

        .sidebar {
            width: 280px;
            background-color: #1b4332; /* Màu xanh rừng đậm */
            color: white;
            height: 100vh;
            position: fixed;
            transition: all 0.3s;
        }

        .main { margin-left: 280px; padding: 40px; min-height: 100vh; }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 14px 24px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: all 0.2s;
            margin: 4px 16px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .nav-link:hover { background-color: rgba(255, 255, 255, 0.1); color: white; }
        .nav-link.active { background-color: #89d957; color: white; box-shadow: 0 4px 15px rgba(137, 217, 87, 0.3); }
        .nav-link i { margin-right: 12px; font-size: 18px; }
        .logo-container { padding: 40px 32px; margin-bottom: 20px; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="logo-container">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-custom rounded-xl flex items-center justify-center shadow-lg">
                    <i class="bi bi-tree-fill text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="text-lg font-black tracking-tighter leading-none">THẢO CẦM VIÊN</h1>
                    <p class="text-[10px] font-bold text-[#89d957] tracking-[0.2em] uppercase opacity-80">Hệ thống quản trị</p>
                </div>
            </div>
        </div>

        <nav>
            @* Mục Tổng quan *@
            <a href="/Admin/Index" class="nav-link @(ViewData["Active"] != null && ViewData["Active"].ToString() == "index" ? "active" : "")">
                <i class="bi bi-grid-fill"></i>
                <span>Tổng quan</span>
            </a>

        @* 3. Quản lý địa điểm (Thay thế cho mục Edit và Delete cũ) *@
            <a href="/Admin/PoiList" class="nav-link @(ViewData["Active"]?.ToString() == "poilist" ? "active" : "")">
                <i class="bi bi-geo-alt-fill"></i>
                <span>Quản lý địa điểm</span>
            </a>

            <a href="/Tour/TourList" class="nav-link @(ViewData["Active"]?.ToString() == "tourlist" ? "active" : "")">
                <i class="bi bi-signpost-split-fill"></i>
                <span>Quản lý tour</span>
            </a>
            
            <div class="px-8 mt-10 mb-4">
                <p class="text-[10px] font-black text-white/30 uppercase tracking-[0.2em]">Cá nhân</p>
            </div>
            
            <a href="/Admin/Logout" class="nav-link text-red-400 hover:bg-red-500/10 hover:text-red-400">
                <i class="bi bi-box-arrow-right"></i>
                <span>Đăng xuất</span>
            </a>
        </nav>
    </aside>

    <main class="main">
        <header class="flex justify-between items-center mb-10">
            <div>
               <h2 class="text-2xl font-bold text-slate-800">@(ViewData["PageTitle"] ?? "Hệ thống quản trị")</h2>
                <p class="text-sm text-slate-400 font-medium">Chào mừng trở lại, Admin Dương</p>
            </div>
            
            <div class="flex items-center gap-4">
                <button class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-100 text-slate-400 shadow-sm">
                    <i class="bi bi-bell-fill"></i>
                </button>
                <div class="h-10 w-[1px] bg-slate-200 mx-2"></div>
                <div class="flex items-center gap-3 bg-white p-1.5 pr-4 rounded-xl border border-slate-100 shadow-sm">
                    <div class="w-8 h-8 rounded-lg bg-gradient-custom flex items-center justify-center text-white font-bold text-xs">
                        AD
                    </div>
                    <span class="text-xs font-black text-slate-700 uppercase tracking-wider">Admin</span>
                </div>
            </div>
        </header>

        @RenderBody()
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>