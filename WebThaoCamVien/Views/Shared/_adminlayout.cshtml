<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - zoo admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
            :root { --primary: #2d6a4f; --dark: #1b4332; --light: #d8f3dc; }
            body { background: #f4f7f6; font-family: 'Segoe UI', sans-serif; display: flex; }
            .sidebar { width: 260px; background: var(--dark); min-height: 100vh; color: white; position: fixed; }
            .main { margin-left: 260px; padding: 25px; width: 100%; }
            .nav-link { color: rgba(255,255,255,0.7); margin: 5px 15px; border-radius: 10px; padding: 12px; text-decoration: none; display: block; }
            .nav-link:hover, .nav-link.active { background: var(--primary); color: white; }
            .card { border: none; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); background: white; }
            .btn-green { background: var(--primary); color: white; border: none; padding: 10px 25px; border-radius: 10px; }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="p-4 text-center border-bottom border-secondary mb-3">
            <h4 class="fw-bold text-success"><i class="fa-solid fa-leaf me-2"></i>zoo cms</h4>
        </div>
        <nav>
            <a href="/admin/index" class="nav-link @(ViewData["Active"] == "index" ? "active" : "")"><i class="fa-solid fa-chart-pie me-2"></i>tổng quan</a>
            <a href="/admin/poi" class="nav-link @(ViewData["Active"] == "poi" ? "active" : "")"><i class="fa-solid fa-map-location-dot me-2"></i>quản lý poi</a>
            <a href="/admin/audio" class="nav-link @(ViewData["Active"] == "audio" ? "active" : "")"><i class="fa-solid fa-microphone-lines me-2"></i>audio & bản dịch</a>
            <a href="/admin/tour" class="nav-link @(ViewData["Active"] == "tour" ? "active" : "")"><i class="fa-solid fa-route me-2"></i>quản lý tour</a>
            <a href="/admin/history" class="nav-link @(ViewData["Active"] == "history" ? "active" : "")"><i class="fa-solid fa-clock-history me-2"></i>lịch sử</a>
            <a href="/admin/login" class="nav-link mt-5 text-danger"><i class="fa-solid fa-power-off me-2"></i>đăng xuất</a>
        </nav>
    </div>

    <div class="main">
        <header class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-3 shadow-sm">
            <h5 class="mb-0 fw-bold">@ViewData["PageTitle"]</h5>
            <span>Chào, <strong>admin</strong></span>
        </header>
        @RenderBody()
    </div>
</body>
</html>