@model WebThaoCamVien.ViewModels.IndexViewModel
@{
    Layout = "_adminlayout";
    ViewData["Active"] = "index";
    ViewData["Title"] = "Lịch sử chi tiết";
    ViewData["PageTitle"] = "Lịch sử thăm quan";
}

@*
    Trang này đã được rút gọn: mọi chart / KPI / top POI đã được chuyển sang
    /Admin/Monitoring. Ở đây chỉ giữ chức năng duy nhất mà Monitoring không
    có — BẢNG LỊCH SỬ CHI TIẾT có phân trang + filter theo từng POI cụ thể.
    Admin dùng để drill-down "POI #7 con hổ đã có ai nghe trong 90 ngày qua".
*@

<style>
    .bg-gradient-custom { background: linear-gradient(90deg, #89d957 10%, #c9e265 100%); }
    .badge-dong-vat { background: #fff4ec; color: #e67e22; }
    .badge-thuc-vat { background: #edfff0; color: #27ae60; }
    .badge-di-tich  { background: #f5eeff; color: #8e44ad; }
</style>

<div class="space-y-6 pb-8">

    @*Banner mô tả + link sang Giám sát *@
    <div class="flex flex-wrap items-center justify-between gap-4 rounded-[24px] border border-slate-100 bg-white px-6 py-4 shadow-sm">
        <div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Drill-down</p>
            <h3 class="text-base font-extrabold text-slate-800 mt-1">Lịch sử thăm quan theo từng POI</h3>
            <p class="text-xs text-slate-500 mt-0.5">Cần tổng quan biểu đồ?
                <a href="/Admin/Monitoring" class="text-[#3d7e1a] font-bold hover:underline">
                    <i class="bi bi-activity"></i> Xem trang Giám sát
                </a>
            </p>
        </div>
        <div class="text-right">
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Tổng lượt (đã lọc)</p>
            <p class="text-2xl font-extrabold text-slate-800 tabular-nums">@Model.TotalVisits.ToString("N0")</p>
        </div>
    </div>

    @*Bảng lịch sử*@
    <div class="bg-white rounded-[24px] border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 flex flex-wrap items-center justify-between gap-4 border-b border-slate-100">
            <div>
                <h3 class="text-sm font-black text-slate-800 uppercase tracking-wide">Bảng lịch sử</h3>
                <p class="text-[11px] text-slate-400 mt-0.5">
                    Trang @Model.CurrentPage / @Model.TotalPages — lọc theo POI hoặc thời gian
                </p>
            </div>

            @*Bo loc*@
            <form method="get" class="flex flex-wrap gap-2">
                <select name="poiId" onchange="this.form.submit()"
                        class="px-3 py-2 rounded-xl bg-slate-50 border-none text-xs font-bold text-slate-600 outline-none focus:ring-2 focus:ring-[#89d957]/30">
                    <option value="">Tất cả địa điểm</option>
                    @foreach (var poi in Model.AllPois)
                    {
                        <option value="@poi.PoiId" selected="@(Model.FilterPoiId == poi.PoiId)">@poi.Name</option>
                    }
                </select>

                <select name="days" onchange="this.form.submit()"
                        class="px-3 py-2 rounded-xl bg-slate-50 border-none text-xs font-bold text-slate-600 outline-none focus:ring-2 focus:ring-[#89d957]/30">
                    <option value="7"  selected="@(Model.FilterDays == 7)">7 ngày qua</option>
                    <option value="30" selected="@(Model.FilterDays == 30)">30 ngày qua</option>
                    <option value="90" selected="@(Model.FilterDays == 90)">90 ngày qua</option>
                    <option value="0"  selected="@(Model.FilterDays == 0)">Tất cả</option>
                </select>

                @if (Model.FilterPoiId.HasValue || Model.FilterDays != 7)
                {
                    <a href="/Admin/Index" class="px-3 py-2 rounded-xl bg-red-50 text-red-400 text-xs font-black">
                        <i class="bi bi-x-lg"></i> Xóa lọc
                    </a>
                }
            </form>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="bg-slate-50">
                        <th class="text-left text-[10px] font-black text-slate-400 uppercase tracking-widest px-6 py-3">Thời gian</th>
                        <th class="text-left text-[10px] font-black text-slate-400 uppercase tracking-widest px-6 py-3">Địa điểm</th>
                        <th class="text-left text-[10px] font-black text-slate-400 uppercase tracking-widest px-6 py-3">Danh mục</th>
                        <th class="text-right text-[10px] font-black text-slate-400 uppercase tracking-widest px-6 py-3">Thời gian nghe</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.RecentVisits.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-12 text-slate-300">
                                <i class="bi bi-clock-history text-4xl block mb-2"></i>
                                <span class="text-sm font-bold">Chưa có dữ liệu</span>
                            </td>
                        </tr>
                    }
                    @foreach (var visit in Model.RecentVisits)
                    {
                        var badgeClass = visit.CategoryId == 1 ? "badge-dong-vat" : visit.CategoryId == 2 ? "badge-thuc-vat" : "badge-di-tich";
                        var catName = visit.CategoryId == 1 ? "Động vật" : visit.CategoryId == 2 ? "Thực vật" : "Di tích";
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-6 py-4">
                                <p class="text-xs font-bold text-slate-700">@visit.VisitTime?.ToString("HH:mm")</p>
                                <p class="text-[10px] text-slate-400">@visit.VisitTime?.ToString("dd/MM/yyyy")</p>
                            </td>
                            <td class="px-6 py-4">
                                <p class="text-xs font-bold text-slate-700">@(visit.PoiName ?? "Không rõ")</p>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-[10px] font-bold px-2 py-1 rounded-full @badgeClass">@catName</span>
                            </td>
                            <td class="px-6 py-4 text-right">
                                @if (visit.ListenDuration.HasValue)
                                {
                                    <span class="text-xs font-black text-slate-600">@visit.ListenDuration<span class="text-slate-300">s</span></span>
                                }
                                else
                                {
                                    <span class="text-slate-300 text-xs">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @*Phan trang*@
        @if (Model.TotalPages > 1)
        {
            <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-between">
                <p class="text-[11px] text-slate-400 font-medium">
                    Trang @Model.CurrentPage / @Model.TotalPages
                </p>
                <div class="flex gap-1">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        var isActive = i == Model.CurrentPage;
                        <a href="?page=@i&poiId=@Model.FilterPoiId&days=@Model.FilterDays"
                           class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-black @(isActive ? "bg-gradient-custom text-white" : "bg-slate-100 text-slate-500 hover:bg-slate-200")">
                            @i
                        </a>
                    }
                </div>
            </div>
        }
    </div>

</div>
