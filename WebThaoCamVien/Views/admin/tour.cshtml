@{
    Layout = "_adminlayout";
    ViewData["Title"] = "quản lý tour";
    ViewData["Active"] = "tour";
    ViewData["PageHeader"] = "thiết lập lộ trình tham quan";
}

<div class="row g-4">
    <div class="col-md-5">
        <div class="card h-100">
            <h5 class="fw-bold text-success mb-3">tạo tour mới</h5>
            <input type="text" class="form-control mb-3" placeholder="tên tour (vd: tour khám phá thú dữ)">
            <div class="list-group">
                <div class="list-group-item d-flex justify-content-between align-items-center rounded-3 mb-2 border-success">
                    1. cổng chính <i class="fa-solid fa-bars text-muted"></i>
                </div>
                <div class="list-group-item d-flex justify-content-between align-items-center rounded-3 mb-2">
                    2. chuồng voi <i class="fa-solid fa-bars text-muted"></i>
                </div>
            </div>
            <button class="btn btn-outline-success w-100 mt-3 border-dashed">+ thêm điểm dừng</button>
            <button class="btn-green w-100 mt-3 shadow">xác nhận lộ trình</button>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card h-100 bg-light d-flex align-items-center justify-content-center border-2 border-dashed">
            <div class="text-center text-muted">
                <i class="fa-solid fa-route fs-1 mb-3"></i>
                <p>bản đồ mô phỏng tour sẽ hiển thị tại đây</p>
            </div>
        </div>
    </div>
</div>