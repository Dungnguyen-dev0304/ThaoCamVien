@{
    Layout = "_adminlayout";
    ViewData["Title"] = "Quản lý poi";
    ViewData["Active"] = "poi";
    ViewData["PageTitle"] = "Quản lý điểm tham quan (poi)";
}

<div class="card p-4">
    <div class="d-flex justify-content-between mb-4">
        <h5 class="fw-bold text-success">Danh sách điểm tham quan</h5>
        <button class="btn btn-success" style="background: #2d6a4f;">+ thêm mới</button>
    </div>
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Tên poi</th>
                <th>Tọa độ</th>
                <th>Audio</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>chuồng voi châu á</td>
                <td>10.787, 106.704</td>
                <td><i class="fa-solid fa-circle-check text-success"></i></td>
                <td>
                    <button class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></button>
                    <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                </td>
            </tr>
        </tbody>
    </table>
</div>