@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - Hệ thống quản lý</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Áp dụng Gradient từ mã XAML của bạn */
        .bg-gradient-custom {
        background: linear-gradient(90deg, #89d957 10%, #c9e265 100%);
        }
        
        .glass-effect {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        }
    </style>
</head>
<body class="bg-gradient-custom h-screen flex items-center justify-center font-sans">

    <div class="w-full max-w-md p-8 mx-4 glass-effect rounded-2xl shadow-2xl">
        <div class="text-center mb-10">
            <div class="inline-block p-4 rounded-full bg-white shadow-sm mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-[#89d957]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
            </div>
            <h2 class="text-3xl font-bold text-gray-800">Admin Login</h2>
            <p class="text-gray-500 mt-2">Vui lòng đăng nhập để tiếp tục</p>
        </div>

        <form method="post" action="/Admin/Login">
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tài khoản</label>
                    <input type="text" name="username" required
                           class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-[#89d957] focus:border-transparent outline-none transition-all"
                           placeholder="Nhập username...">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
                    <input type="password" name="password" required
                           class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:ring-2 focus:ring-[#89d957] focus:border-transparent outline-none transition-all"
                           placeholder="••••••••">
                </div>

                <div class="flex items-center justify-between">
                    <label class="flex items-center">
                        <input type="checkbox" class="rounded text-[#89d957] focus:ring-[#89d957]">
                        <span class="ml-2 text-sm text-gray-600">Ghi nhớ tôi</span>
                    </label>
                    <a href="#" class="text-sm font-medium text-[#89d957] hover:underline">Quên mật khẩu?</a>
                </div>

                <button type="submit"
                        class="w-full py-3 px-4 bg-gradient-custom text-white font-bold rounded-lg shadow-lg hover:opacity-90 transform hover:-translate-y-0.5 transition-all duration-200">
                    ĐĂNG NHẬP
                </button>
            </div>
        </form>

        <div class="mt-8 text-center text-sm text-gray-400">
            &copy; @DateTime.Now.Year - Admin Dashboard System
        </div>
    </div>

</body>
</html>