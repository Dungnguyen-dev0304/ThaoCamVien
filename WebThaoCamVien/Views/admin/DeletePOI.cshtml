@model SharedThaoCamVien.Models.Poi
@{
    Layout = "_adminlayout";
}

<style>
    .bg-custom-primary { background-color: #89d957; }
    #map { height: 350px; width: 100%; border-radius: 24px; z-index: 1; }
</style>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://cdn.tailwindcss.com"></script>

<div class="p-4 max-w-2xl mx-auto">
    <div class="bg-white p-8 rounded-[32px] shadow-sm border border-slate-100">

        <div class="flex flex-col items-center text-center mb-8">
            <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mb-4">
                <i class="bi bi-trash3 text-3xl text-red-500"></i>
            </div>
            <h3 class="text-xl font-black text-slate-800 uppercase">Xác nhận xóa địa điểm</h3>
            <p class="text-slate-400 text-sm mt-1">Hành động này không thể hoàn tác</p>
        </div>

        <div class="bg-slate-50 rounded-2xl p-5 mb-6 space-y-3">
            <div class="flex justify-between items-center">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tên địa điểm</span>
                <span class="font-bold text-slate-700">@Model.Name</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Danh mục</span>
                <span class="font-bold text-slate-700">
                    @(Model.CategoryId == 1 ? "Động vật" : Model.CategoryId == 2 ? "Thực vật" : "Di tích")
                </span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tọa độ</span>
                <span class="font-mono text-sm text-slate-500">@Model.Latitude, @Model.Longitude</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Mô tả</span>
                    <p class="text-slate-600 text-sm mt-1">@Model.Description</p>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.ImageThumbnail))
            {
                <div>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Hình ảnh</span>
                    <img src="/images/pois/@Model.ImageThumbnail" class="w-full h-32 object-cover rounded-xl mt-2 shadow-sm" />
                </div>
            }
        </div>

        <div class="mb-6 rounded-[24px] overflow-hidden border border-slate-100 shadow-sm">
            <div id="map"></div>
        </div>

        <form asp-controller="Admin" asp-action="DeletePOI" method="post" class="flex gap-3">
            <input type="hidden" asp-for="PoiId" />
            <button type="submit" class="flex-1 py-4 bg-red-500 hover:bg-red-600 text-white font-black rounded-xl uppercase tracking-widest text-[11px] transition-colors">
                <i class="bi bi-trash3 mr-2"></i>Xác nhận xóa
            </button>
            <a href="/admin/PoiList" class="py-4 px-6 bg-slate-100 text-slate-500 font-black rounded-xl uppercase tracking-widest text-[11px] flex items-center hover:bg-slate-200 transition-colors">
                Hủy
            </a>
        </form>

    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const categoryColors = {
            "1": "#e67e22",
            "2": "#27ae60",
            "3": "#8e44ad"
        };

        function createCustomIcon(color) {
            return L.divIcon({
                className: 'custom-div-icon',
                html: `<svg width="30" height="42" viewBox="0 0 24 24" fill="${color}" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3" fill="white"></circle></svg>`,
                iconSize: [30, 42],
                iconAnchor: [15, 42]
            });
        }

        const lat = @Model.Latitude;
        const lng = @Model.Longitude;
        const catId = "@Model.CategoryId";
        const color = categoryColors[catId] || "#89d957";

        const map = L.map('map', { zoomControl: false, dragging: false, scrollWheelZoom: false }).setView([lat, lng], 18);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        L.marker([lat, lng], { icon: createCustomIcon(color) }).addTo(map);
    </script>
}
