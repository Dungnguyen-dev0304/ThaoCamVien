@model SharedThaoCamVien.Models.Poi

@{
    Layout = null; // Hoặc Layout của bạn nếu có
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản lý POI - Thảo Cầm Viên</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <style>
        /* Màu xanh mạ chủ đạo của WebThaoCamVien */
        .bg-custom-primary { background-color: #89d957; }
        .text-custom-primary { color: #89d957; }
        .bg-gradient-custom {
            background: linear-gradient(90deg, #89d957 10%, #c9e265 100%);
        }

        /* Sidebar màu tối */
        .sidebar-dark { background-color: #1a1c2e; }
        .sidebar-item-active {
            background: linear-gradient(90deg, #3b82f6 0%, #2563eb 100%);
            box-shadow: 0 4px 15px rgba(37, 99, 235, 0.4);
        }

        #map { height: 100%; width: 100%; border-radius: 0 24px 24px 0; }
        .custom-shadow { box-shadow: 0 10px 40px rgba(0,0,0,0.04); }
        input, select, textarea { border: 1px solid #f1f5f9 !important; }

        /* MÀU MARKER (Dùng CSS Filter để đổi màu icon mặc định) */
        /* Mặc định (Động vật - Xanh dương) */
        .marker-animal { filter: hue-rotate(0deg); }
        /* Thực vật (Xanh lá) */
        .marker-plant { filter: hue-rotate(140deg) brightness(1.2); }
        /* Di tích (Cam/Đỏ) */
        .marker-history { filter: hue-rotate(320deg); }
    </style>
</head>
<body class="bg-[#fcfdfe] font-sans antialiased">

    <div class="flex min-h-screen">
        
        <aside class="w-64 sidebar-dark text-gray-400 flex flex-col shrink-0 sticky top-0 h-screen">
            <div class="p-6 flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 12l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-white font-bold text-lg leading-tight uppercase">POI Admin</h2>
                    <p class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">WebThaoCamVien</p>
                </div>
            </div>

            <nav class="flex-1 px-4 space-y-2 mt-4">
                <a href="#" class="flex items-center gap-3 px-4 py-3 text-white sidebar-item-active rounded-xl transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="text-sm font-semibold">POIs Management</span>
                </a>
                <a href="#" class="flex items-center gap-3 px-4 py-3 hover:bg-white/5 hover:text-white rounded-xl transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
                    </svg>
                    <span class="text-sm font-semibold">Tours Builder</span>
                </a>
            </nav>

            <div class="p-6 border-t border-white/5">
                <a href="#" class="flex items-center gap-3 text-gray-500 hover:text-red-400 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                    </svg>
                    <span class="text-sm font-bold uppercase tracking-widest">Logout</span>
                </a>
            </div>
        </aside>

        <main class="flex-1 flex flex-col">
            
            <header class="h-20 bg-white border-b border-slate-100 flex items-center justify-between px-10 sticky top-0 z-50">
                <h2 class="text-xl font-black text-slate-800">Points of Interest</h2>
                <div class="flex items-center gap-4">
                    <div class="text-right">
                        <span class="block text-sm font-bold text-slate-900">Admin Dương</span>
                        <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest">System Administrator</span>
                    </div>
                    <div class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center font-black text-slate-400 border border-slate-200">AD</div>
                </div>
            </header>

            <div class="p-8 grid grid-cols-1 xl:grid-cols-12 gap-0 overflow-hidden">
                
                <div class="xl:col-span-5 bg-white p-10 rounded-l-[32px] custom-shadow border-y border-l border-slate-100 sticky top-28 h-fit">
                    <div class="flex items-center justify-between mb-8">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-blue-50 text-blue-600 rounded-lg">📍</div>
                            <h3 class="text-lg font-black text-slate-800 uppercase tracking-tight">New POI</h3>
                        </div>
                    </div>

                    <form asp-controller="Admin" asp-action="AddPOI" method="post" class="space-y-6">
                        
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Name</label>
                            <input asp-for="Name" placeholder="Enter POI name..." class="w-full px-5 py-4 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-medium text-slate-700">
                            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <div>
                            <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Category</label>
                            <select id="categorySelect" class="w-full px-5 py-4 rounded-xl bg-slate-50 border-none outline-none appearance-none font-medium text-slate-700">
                                <option value="Động vật">Động vật</option>
                                <option value="Thực vật">Thực vật</option>
                                <option value="Di tích">Di tích</option>
                            </select>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Lat</label>
                                <input asp-for="Latitude" readonly class="w-full px-5 py-4 rounded-xl bg-slate-100 border-none text-slate-400 font-mono text-sm cursor-not-allowed" value="10.7875">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Lng</label>
                                <input asp-for="Longitude" readonly class="w-full px-5 py-4 rounded-xl bg-slate-100 border-none text-slate-400 font-mono text-sm cursor-not-allowed" value="106.7053">
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Description</label>
                            <textarea asp-for="Description" rows="4" placeholder="Brief description..." class="w-full px-5 py-4 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-medium text-slate-700"></textarea>
                        </div>

                        <div class="flex items-center gap-4 pt-4">
                            <button type="submit" class="flex-1 py-4 bg-gradient-custom text-white font-black rounded-xl shadow-lg shadow-[#89d957]/20 hover:scale-[1.02] active:scale-[0.98] transition-all uppercase tracking-widest text-[11px] flex items-center justify-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4" />
                                </svg>
                                Save POI
                            </button>
                            <a href="@Url.Action("Index", "Admin")" class="px-6 py-4 text-slate-400 font-bold hover:text-slate-600 transition-all text-[11px] uppercase tracking-widest text-center">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>

                <div class="xl:col-span-7 bg-white rounded-r-[32px] custom-shadow border-y border-r border-slate-100 overflow-hidden relative min-h-[600px] xl:min-h-[750px]">
                    <div id="map"></div>
                    <div class="absolute bottom-6 right-6 bg-white/90 backdrop-blur-md p-5 rounded-2xl shadow-2xl z-[1000] border border-white w-48">
                        <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Map Legend</h4>
                        <div class="space-y-2">
                            <div class="flex items-center gap-2 text-[11px] font-bold text-slate-600">
                                <div class="w-2.5 h-2.5 rounded-full bg-blue-500 marker-animal"></div> Động vật
                            </div>
                            <div class="flex items-center gap-2 text-[11px] font-bold text-slate-600">
                                <div class="w-2.5 h-2.5 rounded-full bg-green-500 marker-plant"></div> Thực vật
                            </div>
                            <div class="flex items-center gap-2 text-[11px] font-bold text-slate-600">
                                <div class="w-2.5 h-2.5 rounded-full bg-orange-500 marker-history"></div> Di tích
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // --- 1. Khởi tạo bản đồ Thảo Cầm Viên ---
        const map = L.map('map', { zoomControl: false }).setView([10.7875, 106.7053], 17);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        L.control.zoom({ position: 'topleft' }).addTo(map);

        let currentMarker = null;

        // --- 2. Hàm lấy class màu dựa trên Category (Tương ứng với CSS filter ở trên) ---
        function getMarkerClass(category) {
            if (category === "Thực vật") return "marker-plant"; // Xanh lá
            if (category === "Di tích") return "marker-history"; // Cam/Đỏ
            return "marker-animal"; // Mặc định: Động vật (Xanh dương)
        }

        // --- 3. Hàm vẽ Marker mới ---
        function updateMarker(lat, lng) {
            const category = document.getElementById('categorySelect').value;
            const colorClass = getMarkerClass(category);

            if (currentMarker) map.removeLayer(currentMarker);

            // Tạo icon với class màu động
            const myIcon = L.icon({
                iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
                shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
                className: colorClass // Áp dụng màu CSS ở đây
            });

            currentMarker = L.marker([lat, lng], { icon: myIcon }).addTo(map);
        }

        // --- 4. Sự kiện khi Click bản đồ ---
        map.on('click', function(e) {
            const lat = e.latlng.lat.toFixed(6);
            const lng = e.latlng.lng.toFixed(6);

            // ⚠️ LƯU Ý QUAN TRỌNG: Gán tọa độ vào ID mặc định của asp-for (viết hoa chữ cái đầu)
            document.getElementById('Latitude').value = lat; 
            document.getElementById('Longitude').value = lng;

            updateMarker(lat, lng);
        });

        // --- 5. Sự kiện khi thay đổi Dropdown Category (Để đổi màu marker ngay lập tức) ---
        document.getElementById('categorySelect').addEventListener('change', function() {
            // Lấy tọa độ hiện tại từ các ô input
            const lat = document.getElementById('Latitude').value;
            const lng = document.getElementById('Longitude').value;
            
            // Nếu đã chọn điểm trên bản đồ, cập nhật lại marker với màu mới
            if (lat && lng) {
                updateMarker(lat, lng);
            }
        });
    </script>
</body>
</html>