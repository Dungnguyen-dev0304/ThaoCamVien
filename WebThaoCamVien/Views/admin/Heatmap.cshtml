@{
    Layout = "_adminlayout";
    ViewData["Title"] = "Bản đồ nhiệt";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<style>
    #heatmap {
        height: 620px;
        width: 100%;
        border-radius: 18px;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.06);
    }
    .hm-card { background: #fff; border-radius: 18px; padding: 24px; box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04); }
    .hm-stat-card {
        background: #fff;
        border-radius: 18px;
        padding: 20px 24px;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
        border-left: 4px solid #89d957;
    }
    .hm-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 14px; border-radius: 999px;
        font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
        background: #eefbe3; color: #3d7e1a;
    }
    .hm-btn {
        padding: 10px 18px; border-radius: 12px; font-weight: 700; font-size: 13px;
        border: 1px solid #e2e8f0; background: #fff; color: #475569; transition: all .2s;
        cursor: pointer;
    }
    .hm-btn:hover { border-color: #89d957; color: #1b4332; }
    .hm-btn.active { background: #89d957; border-color: #89d957; color: #fff; box-shadow: 0 4px 12px rgba(137,217,87,0.35); }
    .leaflet-tile { filter: saturate(0.9) brightness(1.02); }
    .legend-bar {
        height: 10px; width: 100%; border-radius: 999px;
        background: linear-gradient(90deg, #2b83ff 0%, #00ffff 30%, #00ff00 55%, #ffff00 75%, #ff8000 90%, #ff0000 100%);
    }
</style>

<div class="mb-6 flex items-start justify-between flex-wrap gap-4">
    <div>
        <span class="hm-pill">
            <i class="bi bi-fire"></i> Heatmap mật độ
        </span>
        <h3 class="text-xl font-extrabold text-slate-800 mt-3">Bản đồ nhiệt thăm quan Thảo Cầm Viên</h3>
        <p class="text-sm text-slate-500 mt-1">
            Dữ liệu lấy từ bảng <code class="bg-slate-100 px-2 py-0.5 rounded text-[12px]">poi_visit_history</code>
            &mdash; mỗi POI là 1 điểm, trọng số = số lượt thăm trong khoảng thời gian đã chọn.
        </p>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
        <span class="text-[11px] font-black text-slate-400 uppercase tracking-wider mr-2">Khoảng thời gian</span>
        <button class="hm-btn" data-days="1">24 giờ</button>
        <button class="hm-btn" data-days="7">7 ngày</button>
        <button class="hm-btn active" data-days="30">30 ngày</button>
        <button class="hm-btn" data-days="90">90 ngày</button>
        <button class="hm-btn" data-days="365">1 năm</button>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="hm-stat-card">
        <p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.15em]">Số POI có lượt thăm</p>
        <p class="text-3xl font-extrabold text-slate-800 mt-1" id="stat-points">—</p>
    </div>
    <div class="hm-stat-card" style="border-left-color:#f59e0b;">
        <p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.15em]">Tổng lượt thăm (đã lọc)</p>
        <p class="text-3xl font-extrabold text-slate-800 mt-1" id="stat-weight">—</p>
    </div>
    <div class="hm-stat-card" style="border-left-color:#3b82f6;">
        <p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.15em]">Cập nhật lần cuối</p>
        <p class="text-base font-bold text-slate-700 mt-2" id="stat-updated">—</p>
    </div>
</div>

<div class="hm-card mb-6">
    <div id="heatmap"></div>
    <div class="mt-4 flex items-center justify-between gap-6 flex-wrap">
        <div class="flex-1 min-w-[240px]">
            <p class="text-[11px] font-black text-slate-400 uppercase tracking-[0.15em] mb-2">Thang mật độ</p>
            <div class="legend-bar"></div>
            <div class="flex justify-between text-[10px] font-bold text-slate-400 uppercase tracking-wider mt-1">
                <span>Ít lượt</span><span>Trung bình</span><span>Rất nhiều lượt</span>
            </div>
        </div>
        <div class="text-xs text-slate-500 max-w-md">
            <i class="bi bi-info-circle text-[#89d957]"></i>
            Điểm càng đỏ càng nhiều lượt xem/nghe audio. Click vào vùng nóng để xem tên POI và số lượt tích luỹ.
        </div>
    </div>
</div>

<div class="hm-card">
    <h4 class="text-base font-extrabold text-slate-800 mb-3">Top 10 POI có lượt thăm nhiều nhất (trong khoảng đã chọn)</h4>
    <div id="top-list" class="space-y-2">
        <p class="text-slate-400 text-sm">Đang tải…</p>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

    <script>
        // Tâm Thảo Cầm Viên Sài Gòn (bạn có thể chỉnh lại nếu cần)
        const ZOO_CENTER = [10.7876, 106.7068];
        const map = L.map('heatmap', {
            zoomControl: true,
            preferCanvas: true
        }).setView(ZOO_CENTER, 17);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 20,
            attribution: '© OpenStreetMap'
        }).addTo(map);

        let heatLayer = null;
        let markerLayer = L.layerGroup().addTo(map);
        let currentDays = 30;

        async function loadData(days) {
            currentDays = days;
            setLoading(true);
            try {
                const res = await fetch(`/Admin/HeatmapDataJson?days=${days}&source=visit`, { credentials: 'same-origin' });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();
                render(data);
            } catch (err) {
                console.error(err);
                document.getElementById('top-list').innerHTML =
                    `<p class="text-red-500 text-sm"><i class="bi bi-exclamation-triangle"></i> Không tải được dữ liệu: ${err.message}</p>`;
            } finally {
                setLoading(false);
            }
        }

        function render(data) {
            // 1. Stats
            document.getElementById('stat-points').textContent = (data.totalPoints || 0).toLocaleString('vi-VN');
            document.getElementById('stat-weight').textContent = Math.round(data.totalWeight || 0).toLocaleString('vi-VN');
            document.getElementById('stat-updated').textContent = new Date().toLocaleString('vi-VN');

            // 2. Heatmap layer
            if (heatLayer) { map.removeLayer(heatLayer); heatLayer = null; }
            markerLayer.clearLayers();

            const points = (data.points || []).filter(p => isFinite(p.lat) && isFinite(p.lng));
            if (points.length === 0) {
                document.getElementById('top-list').innerHTML =
                    `<p class="text-slate-400 text-sm"><i class="bi bi-inbox"></i> Chưa có lượt thăm nào trong khoảng thời gian này.</p>`;
                return;
            }

            const maxWeight = Math.max(...points.map(p => p.weight || 1));
            const heatPoints = points.map(p => [p.lat, p.lng, Math.max(0.2, (p.weight || 1) / maxWeight)]);

            heatLayer = L.heatLayer(heatPoints, {
                radius: 35,
                blur: 25,
                maxZoom: 19,
                max: 1.0,
                gradient: {
                    0.1: '#2b83ff',
                    0.3: '#00ffff',
                    0.55: '#00ff00',
                    0.75: '#ffff00',
                    0.9: '#ff8000',
                    1.0: '#ff0000'
                }
            }).addTo(map);

            // 3. Markers có popup (để click xem tên POI + số lượt)
            points.forEach(p => {
                const marker = L.circleMarker([p.lat, p.lng], {
                    radius: 6 + Math.min(12, (p.weight / maxWeight) * 14),
                    weight: 1.5,
                    color: '#1b4332',
                    fillColor: '#89d957',
                    fillOpacity: 0.35
                });
                marker.bindPopup(`
                    <div style="font-family:Inter,sans-serif">
                        <div style="font-weight:800;font-size:13px;color:#1b4332">${p.name || '(không tên)'}</div>
                        <div style="font-size:12px;color:#475569;margin-top:4px">
                            <i class="bi bi-fire" style="color:#f59e0b"></i>
                            Số lượt thăm: <b>${p.weight.toLocaleString('vi-VN')}</b>
                        </div>
                        <div style="font-size:11px;color:#94a3b8;margin-top:2px">
                            ${p.lat.toFixed(6)}, ${p.lng.toFixed(6)}
                        </div>
                    </div>
                `);
                markerLayer.addLayer(marker);
            });

            // 4. Top 10 list
            const sorted = [...points].sort((a, b) => b.weight - a.weight).slice(0, 10);
            const maxW = sorted[0].weight;
            document.getElementById('top-list').innerHTML = sorted.map((p, i) => `
                <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-slate-50 transition">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center font-black text-xs text-white"
                         style="background:${rankColor(i)}">${i + 1}</div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-bold text-slate-700 truncate">${escapeHtml(p.name || '(không tên)')}</p>
                        <div class="h-1.5 bg-slate-100 rounded-full mt-2 overflow-hidden">
                            <div style="width:${(p.weight / maxW) * 100}%;height:100%;background:linear-gradient(90deg,#89d957,#f59e0b);"></div>
                        </div>
                    </div>
                    <span class="text-sm font-black text-slate-800">${p.weight.toLocaleString('vi-VN')}</span>
                </div>
            `).join('');
        }

        function rankColor(i) {
            if (i === 0) return '#ef4444';
            if (i === 1) return '#f59e0b';
            if (i === 2) return '#eab308';
            return '#89d957';
        }

        function escapeHtml(s) {
            return (s + '').replace(/[&<>"']/g, c => ({
                '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
            }[c]));
        }

        function setLoading(v) {
            document.getElementById('stat-updated').textContent = v ? 'Đang tải…' : new Date().toLocaleString('vi-VN');
        }

        document.querySelectorAll('.hm-btn[data-days]').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.hm-btn[data-days]').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                loadData(parseInt(btn.dataset.days, 10));
            });
        });

        // Auto-load 30 ngày mặc định
        loadData(30);
    </script>
}
