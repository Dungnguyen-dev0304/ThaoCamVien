@model WebThaoCamVien.ViewModels.EditPOIViewModel
@{
    Layout = "_adminlayout";
    var languages = new[] {
        new { Code = "vi", Label = "Tiếng Việt", Flag = "🇻🇳" },
        new { Code = "en", Label = "English",    Flag = "🇬🇧" },
        new { Code = "fr", Label = "Français",   Flag = "🇫🇷" },
        new { Code = "zh", Label = "中文",        Flag = "🇨🇳" },
        new { Code = "ja", Label = "日本語",       Flag = "🇯🇵" },
        new { Code = "ko", Label = "한국어",       Flag = "🇰🇷" },
    };
}

<style>
    .bg-custom-primary { background-color: #89d957; }
    .bg-gradient-custom { background: linear-gradient(90deg, #89d957 10%, #c9e265 100%); }
    #map { height: 600px; width: 100%; border-radius: 24px; z-index: 1; }
    .upload-area { border: 2px dashed #89d957; background: #f9fff4; cursor: pointer; transition: all 0.3s ease; }
    .upload-area:hover { background: #f0fce6; border-color: #c9e265; }
    .opt-dong-vat { color: #e67e22; font-weight: bold; }
    .opt-thuc-vat { color: #27ae60; font-weight: bold; }
    .opt-di-tich { color: #8e44ad; font-weight: bold; }
    .lang-tab { cursor: pointer; transition: all 0.2s; }
    .lang-tab.active { background: linear-gradient(90deg, #89d957 10%, #c9e265 100%); color: white; border-color: transparent; }
    .lang-panel { display: none; }
    .lang-panel.active { display: block; }
</style>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://cdn.tailwindcss.com"></script>

 @*PHẦN 1: FORM CHỈNH SỬA POI*@
<div class="p-4 grid grid-cols-1 xl:grid-cols-12 gap-6">
    <div class="xl:col-span-5 bg-white p-8 rounded-[32px] shadow-sm border border-slate-100">
        <h3 class="text-lg font-black text-slate-800 uppercase mb-6 flex items-center">
            <span class="w-8 h-8 bg-custom-primary text-white rounded-lg flex items-center justify-center mr-3">
                <i class="bi bi-pencil"></i>
            </span>
            Chỉnh sửa địa điểm
        </h3>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl mb-4 text-sm font-medium">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>⚠️ @error.ErrorMessage</p>
                }
            </div>
        }

        <form asp-controller="Admin" asp-action="EditPOI" method="post" enctype="multipart/form-data" class="space-y-5">
            <input type="hidden" asp-for="Poi.PoiId" />

            <div>
                <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Tên địa điểm</label>
                <input asp-for="Poi.Name" class="w-full px-4 py-3 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-medium" placeholder="Nhập tên địa điểm...">
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Danh mục</label>
                <select asp-for="Poi.CategoryId" id="CategorySelect" class="w-full px-4 py-3 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-medium">
                    <option value="">-- Chọn loại hình --</option>
                    <option value="1" class="opt-dong-vat">Động vật</option>
                    <option value="2" class="opt-thuc-vat">Thực vật</option>
                    <option value="3" class="opt-di-tich">Di tích</option>
                </select>
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Hình ảnh (Thumbnail)</label>
                @if (!string.IsNullOrEmpty(Model.Poi.ImageThumbnail))
                {
                    <div class="mb-2">
                        <p class="text-[10px] text-slate-400 mb-1 uppercase font-bold">Ảnh hiện tại:</p>
                        <img src="/images/pois/@Model.Poi.ImageThumbnail" class="w-full h-32 object-cover rounded-xl shadow-sm" />
                    </div>
                }
                <div class="upload-area p-5 rounded-xl text-center relative" onclick="document.getElementById('imageFile').click()">
                    <div id="uploadText">
                        <i class="bi bi-image text-2xl text-[#89d957]"></i>
                        <p class="text-[10px] font-bold text-slate-500 mt-1 uppercase">Chọn ảnh mới (để trống nếu không đổi)</p>
                    </div>
                    <img id="imgPreview" src="#" class="hidden w-full h-32 object-cover rounded-lg shadow-sm" />
                    <input type="file" id="imageFile" name="imageFile" class="hidden" accept="image/*" onchange="handlePreview(this)">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Vĩ độ</label>
                    <input asp-for="Poi.Latitude" id="Latitude" class="w-full px-4 py-3 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-mono text-sm">
                </div>
                <div>
                    <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Kinh độ</label>
                    <input asp-for="Poi.Longitude" id="Longitude" class="w-full px-4 py-3 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-mono text-sm">
                </div>
            </div>

            <div>
                <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Mô tả</label>
                <textarea asp-for="Poi.Description" rows="3" class="w-full px-4 py-3 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all"></textarea>
            </div>

            <div class="flex gap-3">
                <button type="submit" class="flex-1 py-4 bg-gradient-custom text-white font-black rounded-xl shadow-lg shadow-[#89d957]/20 uppercase tracking-widest text-[11px]">
                    Lưu thay đổi
                </button>
                <a href="/admin/PoiList" class="py-4 px-6 bg-slate-100 text-slate-500 font-black rounded-xl uppercase tracking-widest text-[11px] flex items-center">
                    Hủy
                </a>
            </div>
        </form>
    </div>

    <div class="xl:col-span-7 bg-white rounded-[32px] shadow-sm border border-slate-100 overflow-hidden relative">
        <div id="mapError" class="hidden absolute top-4 left-1/2 -translate-x-1/2 z-[999] bg-red-500 text-white text-xs font-bold px-4 py-2 rounded-xl shadow-lg whitespace-nowrap"></div>
        <div id="map"></div>
    </div>
</div>

 @*PHẦN 2: Quản lý bản dịch*@
<div class="px-4 pb-4 mt-2">
    <div class="bg-white p-8 rounded-[32px] shadow-sm border border-slate-100">
        <h3 class="text-lg font-black text-slate-800 uppercase mb-6 flex items-center">
            <span class="w-8 h-8 bg-custom-primary text-white rounded-lg flex items-center justify-center mr-3">
                <i class="bi bi-translate"></i>
            </span>
            Bản dịch địa điểm
            <span class="ml-3 text-[11px] bg-slate-100 text-slate-500 font-bold px-3 py-1 rounded-full">
                @Model.Translations.Count / @languages.Length ngôn ngữ
            </span>
        </h3>

         @*TAB NGÔN NGỮ*@
        <div class="flex gap-2 flex-wrap mb-6">
            @foreach (var lang in languages)
            {
                var existing = Model.Translations.FirstOrDefault(t => t.LanguageCode == lang.Code);
                <button type="button"
                        onclick="switchTab('@lang.Code')"
                        id="tab-@lang.Code"
                        class="lang-tab px-4 py-2 rounded-xl text-xs font-black uppercase tracking-widest border border-slate-200 text-slate-500 flex items-center gap-2">
                    <span>@lang.Flag</span>
                    <span>@lang.Label</span>
                    @if (existing != null)
                    {
                        <span class="w-2 h-2 bg-[#89d957] rounded-full inline-block"></span>
                    }
                </button>
            }
        </div>

         @*PANNEL TỪNG NGÔN NGỮ*@
        @foreach (var lang in languages)
        {
            var existing = Model.Translations.FirstOrDefault(t => t.LanguageCode == lang.Code);
            <div id="panel-@lang.Code" class="lang-panel">
                <form asp-controller="Admin" asp-action="SaveTranslation" method="post" class="space-y-4">
                    <input type="hidden" name="PoiId" value="@Model.Poi.PoiId" />
                    <input type="hidden" name="LanguageCode" value="@lang.Code" />
                    <input type="hidden" name="TranslationId" value="@(existing?.TranslationId ?? 0)" />

                    <div class="bg-slate-50 rounded-2xl p-5 space-y-4">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-xl">@lang.Flag</span>
                            <span class="text-sm font-black text-slate-700 uppercase tracking-widest">@lang.Label</span>
                            @if (existing != null)
                            {
                                <span class="text-[10px] bg-green-100 text-green-600 font-bold px-2 py-0.5 rounded-full uppercase">Đã có bản dịch</span>
                            }
                            else
                            {
                                <span class="text-[10px] bg-slate-200 text-slate-500 font-bold px-2 py-0.5 rounded-full uppercase">Chưa có bản dịch</span>
                            }
                        </div>

                        <div>
                            <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Tên địa điểm</label>
                            <input type="text" name="Name" value="@(existing?.Name ?? "")"
                                   id="name-@lang.Code"
                                   oninput="updatePreview('@lang.Code')"
                                   class="w-full px-4 py-3 rounded-xl bg-white border border-slate-200 outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all font-medium"
                                   placeholder="Tên địa điểm bằng @lang.Label...">
                        </div>

                        <div>
                            <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Mô tả / Nội dung Text-to-Speech</label>
                            <textarea name="Description" rows="4"
                                      id="desc-@lang.Code"
                                      oninput="updatePreview('@lang.Code')"
                                      class="w-full px-4 py-3 rounded-xl bg-white border border-slate-200 outline-none focus:ring-2 focus:ring-[#89d957]/30 transition-all"
                                      placeholder="Mô tả bằng @lang.Label (dùng cho TTS trên ứng dụng mobile)...">@(existing?.Description ?? "")</textarea>
                        </div>

                         @*PREVIEW MOCKUP PHONE*@
                        <div>
                            <label class="block text-[10px] font-black text-slate-400 mb-2 uppercase tracking-widest">Preview trên app</label>
                            
                            @*PHONE FRAME*@
                            <div class="flex justify-center">
                                <div style="width:260px; background:#111; border-radius:36px; padding:10px; box-shadow: 0 25px 50px rgba(0,0,0,0.3);">
                                    
                                    <div style="background:#1a3a2a; border-radius:28px; overflow:hidden;">
                                        <div style="background:#111; height:20px; border-radius:0 0 16px 16px; margin:0 60px;"></div>
                                        
                                         @*STATUS BAR*@
                                        <div style="background:#1a3a2a; padding:6px 16px; display:flex; justify-content:space-between; align-items:center;">
                                            <span style="color:white; font-size:10px; font-weight:bold;">@lang.Flag @lang.Label</span>
                                            <span style="color:white; font-size:10px;">📶 🔋</span>
                                        </div>

                                        @*ANIMAL SCREEN*@
                                        <div style="background:#1a3a2a; padding:12px; min-height:420px;">
                                             @*TITTLE*@
                                            <p style="color:white; font-size:13px; font-weight:900; text-align:center; margin-bottom:12px; letter-spacing:0.05em;">Thảo Cầm Viên</p>

                                            @*SEARCH BAR*@
                                            <div style="background:white; border-radius:20px; padding:6px 12px; display:flex; align-items:center; gap:6px; margin-bottom:14px;">
                                                <span style="font-size:12px;">🔍</span>
                                                <span style="color:#aaa; font-size:10px;">Tìm kiếm địa điểm...</span>
                                            </div>

                                            @*GRILL POI CARD*@
                                            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
                                             
                                                <div style="background:#1e4d33; border-radius:14px; overflow:hidden; border:2px solid #89d957;">
                                                    @if (!string.IsNullOrEmpty(Model.Poi.ImageThumbnail))
                                                    {
                                                        <img src="/images/pois/@Model.Poi.ImageThumbnail" style="width:100%; height:70px; object-fit:cover;" />
                                                    }
                                                    else
                                                    {
                                                        <div style="width:100%; height:70px; background:#2a5a3a; display:flex; align-items:center; justify-content:center;">
                                                            <span style="font-size:20px;">🌿</span>
                                                        </div>
                                                    }
                                                    <div style="padding:6px 8px;">
                                                        <p id="preview-name-@lang.Code" style="color:white; font-size:10px; font-weight:900; margin:0 0 2px 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                            @(existing?.Name ?? Model.Poi.Name)
                                                        </p>
                                                        <p id="preview-desc-@lang.Code" style="color:#a8d5a2; font-size:8px; line-height:1.3; margin:0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                                            @(existing?.Description ?? "Mô tả sẽ hiển thị ở đây...")
                                                        </p>
                                                    </div>
                                                </div>

                                                
                                                <div style="background:#1e4d33; border-radius:14px; overflow:hidden; opacity:0.4;">
                                                    <div style="width:100%; height:70px; background:#2a5a3a;"></div>
                                                    <div style="padding:6px 8px;">
                                                        <div style="height:8px; background:#2a5a3a; border-radius:4px; margin-bottom:4px;"></div>
                                                        <div style="height:6px; background:#2a5a3a; border-radius:4px; width:70%;"></div>
                                                    </div>
                                                </div>

                                                <div style="background:#1e4d33; border-radius:14px; overflow:hidden; opacity:0.4;">
                                                    <div style="width:100%; height:70px; background:#2a5a3a;"></div>
                                                    <div style="padding:6px 8px;">
                                                        <div style="height:8px; background:#2a5a3a; border-radius:4px; margin-bottom:4px;"></div>
                                                        <div style="height:6px; background:#2a5a3a; border-radius:4px; width:80%;"></div>
                                                    </div>
                                                </div>

                                                <div style="background:#1e4d33; border-radius:14px; overflow:hidden; opacity:0.4;">
                                                    <div style="width:100%; height:70px; background:#2a5a3a;"></div>
                                                    <div style="padding:6px 8px;">
                                                        <div style="height:8px; background:#2a5a3a; border-radius:4px; margin-bottom:4px;"></div>
                                                        <div style="height:6px; background:#2a5a3a; border-radius:4px; width:60%;"></div>
                                                    </div>
                                                </div>
                                            </div>

                                           
                                            <div style="display:flex; justify-content:space-around; margin-top:16px; padding-top:10px; border-top:1px solid #2a5a3a;">
                                                <div style="text-align:center; opacity:0.5;">
                                                    <div style="font-size:14px;">🏠</div>
                                                    <div style="color:#aaa; font-size:7px;">Home</div>
                                                </div>
                                                <div style="text-align:center; opacity:0.5;">
                                                    <div style="font-size:14px;">⬛</div>
                                                    <div style="color:#aaa; font-size:7px;">Scan QR</div>
                                                </div>
                                                <div style="text-align:center;">
                                                    <div style="font-size:14px;">🐾</div>
                                                    <div style="color:#89d957; font-size:7px; font-weight:bold;">Animals</div>
                                                </div>
                                                <div style="text-align:center; opacity:0.5;">
                                                    <div style="font-size:14px;">🗺️</div>
                                                    <div style="color:#aaa; font-size:7px;">Map</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            @*NÚT TTS DƯỚI PHONE*@
                            <div class="flex justify-center mt-4">
                                <button type="button"
                                        onclick="speakText('@lang.Code', '@lang.Code')"
                                        id="tts-btn-@lang.Code"
                                        class="flex items-center gap-2 px-5 py-2.5 bg-slate-50 hover:bg-[#89d957]/10 border border-slate-200 rounded-xl text-xs font-black text-slate-600 transition-all">
                                    <i class="bi bi-volume-up-fill text-[#89d957]"></i>
                                    Nghe thử TTS
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-3">
                        <button type="submit" class="px-6 py-3 bg-gradient-custom text-white font-black rounded-xl text-[11px] uppercase tracking-widest shadow-lg shadow-[#89d957]/20">
                            <i class="bi bi-floppy mr-1"></i> Lưu @lang.Flag
                        </button>
                        @if (existing != null)
                        {
                            <form asp-controller="Admin" asp-action="DeleteTranslation" method="post" class="inline">
                                <input type="hidden" name="TranslationId" value="@existing.TranslationId" />
                                <input type="hidden" name="PoiId" value="@Model.Poi.PoiId" />
                                <button type="submit" onclick="return confirm('Xóa bản dịch @lang.Label này?')"
                                        class="px-6 py-3 bg-red-50 text-red-500 font-black rounded-xl text-[11px] uppercase tracking-widest hover:bg-red-100 transition-colors">
                                    <i class="bi bi-trash3 mr-1"></i> Xóa bản dịch
                                </button>
                            </form>
                        }
                    </div>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // ── TAB NGÔN NGỮ ──
        function switchTab(code) {
            document.querySelectorAll('.lang-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.lang-panel').forEach(p => p.classList.remove('active'));
            document.getElementById('tab-' + code).classList.add('active');
            document.getElementById('panel-' + code).classList.add('active');
        }
        switchTab('vi');

        // ── PREVIEW REALTIME ──
        function updatePreview(code) {
            const name = document.getElementById('name-' + code)?.value || 'Tên địa điểm...';
            const desc = document.getElementById('desc-' + code)?.value || 'Mô tả sẽ hiển thị ở đây...';
            const previewName = document.getElementById('preview-name-' + code);
            const previewDesc = document.getElementById('preview-desc-' + code);
            if (previewName) previewName.textContent = name;
            if (previewDesc) previewDesc.textContent = desc;
        }

        // ── TTS (Web Speech API) ──
        const langMap = {
            'vi': 'vi-VN', 'en': 'en-US', 'fr': 'fr-FR',
            'zh': 'zh-CN', 'ja': 'ja-JP', 'ko': 'ko-KR'
        };

        let currentUtterance = null;

        function speakText(code, langCode) {
            if (!window.speechSynthesis) {
                alert('Trình duyệt không hỗ trợ TTS!');
                return;
            }

            // Dừng nếu đang đọc
            if (currentUtterance) {
                window.speechSynthesis.cancel();
                currentUtterance = null;
                resetTtsBtn(code);
                return;
            }

            const desc = document.getElementById('desc-' + code)?.value?.trim();
            if (!desc) {
                alert('Vui lòng nhập mô tả trước khi nghe thử!');
                return;
            }

            const utterance = new SpeechSynthesisUtterance(desc);
            utterance.lang = langMap[langCode] || 'vi-VN';
            utterance.rate = 0.9;

            const btn = document.getElementById('tts-btn-' + code);
            if (btn) {
                btn.innerHTML = '<i class="bi bi-stop-fill text-red-500"></i> Đang đọc... (click để dừng)';
                btn.classList.add('border-red-200', 'bg-red-50');
            }

            utterance.onend = () => {
                currentUtterance = null;
                resetTtsBtn(code);
            };

            utterance.onerror = () => {
                currentUtterance = null;
                resetTtsBtn(code);
            };

            currentUtterance = utterance;
            window.speechSynthesis.speak(utterance);
        }

        function resetTtsBtn(code) {
            const btn = document.getElementById('tts-btn-' + code);
            if (btn) {
                btn.innerHTML = '<i class="bi bi-volume-up-fill text-[#89d957]"></i> Nghe thử TTS';
                btn.classList.remove('border-red-200', 'bg-red-50');
            }
        }

        // ── BẢN ĐỒ ──
        const categoryColors = { "1": "#e67e22", "2": "#27ae60", "3": "#8e44ad" };

        function createCustomIcon(color) {
            return L.divIcon({
                className: 'custom-div-icon',
                html: `<svg width="30" height="42" viewBox="0 0 24 24" fill="${color}" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3" fill="white"></circle></svg>`,
                iconSize: [30, 42], iconAnchor: [15, 42]
            });
        }

        const currentLat = @Model.Poi.Latitude;
        const currentLng = @Model.Poi.Longitude;
        const map = L.map('map').setView([currentLat, currentLng], 17);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        const boundary = [
            [10.790530958743389, 106.70681254947431],[10.790456999508692, 106.70671698845888],
            [10.790257700153376, 106.70651554322427],[10.79042812075069,  106.70628133432854],
            [10.790440902291763, 106.70618591588868],[10.79041107869567,  106.70598640460645],
            [10.790483507424142, 106.70586496295732],[10.790658188404294, 106.70571749809534],
            [10.790530373063206, 106.70559171924418],[10.790564457159661, 106.70547895199752],
            [10.788817019051919, 106.70383791235048],[10.788177937888548, 106.70454487624346],
            [10.787977692177435, 106.7043323533548], [10.784948471879815, 106.70767588372479],
            [10.785033683695005, 106.70775395335602],[10.78498255660898,  106.70786672060262],
            [10.785157240784699, 106.70799683665604],[10.785072029004596, 106.70815731312257],
            [10.787234071848147, 106.70907826576183],[10.78740363601608,  106.70870791908663],
            [10.787693353724208, 106.70829154771366],[10.788434688943752, 106.70767132785807],
            [10.788928911406757, 106.70735037492676],
        ];
        L.polygon(boundary, { color: '#ef4444', weight: 2, fillOpacity: 0.05 }).addTo(map);

        function isInsideBoundary(lat, lng) {
            let inside = false;
            for (let i = 0, j = boundary.length - 1; i < boundary.length; j = i++) {
                const xi = boundary[i][0], yi = boundary[i][1];
                const xj = boundary[j][0], yj = boundary[j][1];
                const intersect = ((yi > lng) !== (yj > lng)) && (lat < (xj - xi) * (lng - yi) / (yj - yi) + xi);
                if (intersect) inside = !inside;
            }
            return inside;
        }

        function showMapError(msg) {
            const el = document.getElementById('mapError');
            el.textContent = msg;
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 4000);
        }

        const categorySelect = document.getElementById('CategorySelect');
        let marker = null;

        function updateMarker(lat, lng) {
            const color = categoryColors[categorySelect.value] || "#89d957";
            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng], { icon: createCustomIcon(color) }).addTo(map);
            document.getElementById('Latitude').value = lat;
            document.getElementById('Longitude').value = lng;
        }

        updateMarker(currentLat, currentLng);

        map.on('click', function(e) {
            if (!isInsideBoundary(e.latlng.lat, e.latlng.lng)) {
                showMapError('⚠️ Vị trí nằm ngoài ranh giới Thảo Cầm Viên!');
                return;
            }
            updateMarker(e.latlng.lat.toFixed(8), e.latlng.lng.toFixed(8));
        });

        categorySelect.addEventListener('change', function() {
            const lat = document.getElementById('Latitude').value;
            const lng = document.getElementById('Longitude').value;
            if (lat && lng) updateMarker(lat, lng);
        });

        document.getElementById('Latitude').addEventListener('change', updateMarkerFromInput);
        document.getElementById('Longitude').addEventListener('change', updateMarkerFromInput);

        function updateMarkerFromInput() {
            const lat = parseFloat(document.getElementById('Latitude').value);
            const lng = parseFloat(document.getElementById('Longitude').value);
            if (isNaN(lat) || isNaN(lng)) return;
            if (!isInsideBoundary(lat, lng)) { showMapError('⚠️ Vị trí nằm ngoài ranh giới Thảo Cầm Viên!'); return; }
            updateMarker(lat.toFixed(8), lng.toFixed(8));
            map.setView([lat, lng], 17);
        }

        function handlePreview(input) {
            const preview = document.getElementById('imgPreview');
            const text = document.getElementById('uploadText');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                    text.classList.add('hidden');
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}
