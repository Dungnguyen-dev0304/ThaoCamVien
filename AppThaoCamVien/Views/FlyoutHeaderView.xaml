<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Views.FlyoutHeaderView">

    <Grid HeightRequest="170" Padding="0,10">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#89d957" Offset="0.1"/>
                <GradientStop Color="#c9e265" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
            <Frame CornerRadius="80" 
                   HeightRequest="120" 
                   WidthRequest="120"
                   Padding="0"
                   IsClippedToBounds="True"
                   HasShadow="False"
                   BackgroundColor="Transparent">
                <Image Source="logothaocamvien.png" Aspect="AspectFill"/>
            </Frame>
        </VerticalStackLayout>
    </Grid>
</ContentView>