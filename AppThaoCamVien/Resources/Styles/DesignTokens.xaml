<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ThaoCamVien Design Tokens — Outdoor / High Contrast / Nature Premium -->
    <!-- Map to ResourceDictionary keys for XAML: {StaticResource Tcv...} -->

    <!-- Brand -->
    <Color x:Key="TcvBrandForest">#1B5E3A</Color>
    <Color x:Key="TcvBrandForestDark">#0F3D26</Color>
    <Color x:Key="TcvMint">#7CB89A</Color>
    <Color x:Key="TcvMintLight">#B8E8D0</Color>
    <Color x:Key="TcvEarthGold">#C9A227</Color>
    <Color x:Key="TcvEarthGoldMuted">#E8D49A</Color>

    <!-- Surfaces (Light outdoor: reduce glare) -->
    <Color x:Key="TcvBackgroundPage">#FAFAF8</Color>
    <Color x:Key="TcvSurfaceCard">#FFFFFF</Color>
    <Color x:Key="TcvSurfaceMuted">#F0F2EF</Color>
    <Color x:Key="TcvOverlayScrim">#66000000</Color>

    <!-- Text (near-black, not #000) -->
    <Color x:Key="TcvTextPrimary">#1A1D1C</Color>
    <Color x:Key="TcvTextSecondary">#3D4540</Color>
    <Color x:Key="TcvTextMuted">#5C6560</Color>
    <Color x:Key="TcvTextOnBrand">#FFFFFF</Color>

    <!-- Borders & dividers -->
    <Color x:Key="TcvBorderSubtle">#DDE3DD</Color>
    <Color x:Key="TcvBorderStrong">#B8C4BA</Color>

    <!-- Semantic state -->
    <Color x:Key="TcvSuccess">#2E7D4A</Color>
    <Color x:Key="TcvSuccessSurface">#E6F4EA</Color>
    <Color x:Key="TcvWarning">#C47F00</Color>
    <Color x:Key="TcvWarningSurface">#FFF4E0</Color>
    <Color x:Key="TcvError">#B3261E</Color>
    <Color x:Key="TcvErrorSurface">#FCE8E6</Color>

    <!-- Spacing grid: 8dp -->
    <x:Double x:Key="TcvSpaceXs">4</x:Double>
    <x:Double x:Key="TcvSpaceS">8</x:Double>
    <x:Double x:Key="TcvSpaceM">16</x:Double>
    <x:Double x:Key="TcvSpaceL">24</x:Double>
    <x:Double x:Key="TcvSpaceXl">32</x:Double>
    <x:Double x:Key="TcvSpace2Xl">40</x:Double>

    <Thickness x:Key="TcvPaddingButton">16,14</Thickness>

    <!-- Corner radius -->
    <x:Double x:Key="TcvRadiusCard">16</x:Double>
    <x:Double x:Key="TcvRadiusButton">12</x:Double>
    <x:Double x:Key="TcvRadiusPill">999</x:Double>
    <x:Double x:Key="TcvRadiusChip">8</x:Double>

    <!-- Touch targets (thumb zone) -->
    <x:Double x:Key="TcvMinTouch">48</x:Double>

    <!-- Typography scale (sp ≈ device-independent; MAUI FontSize) -->
    <!-- Primary UI: OpenSans (bundled). CJK: add Noto Sans JP as MauiFont + TcvFontFamilyJapanese -->
    <x:Double x:Key="TcvFontDisplay">28</x:Double>
    <x:Double x:Key="TcvFontH1">24</x:Double>
    <x:Double x:Key="TcvFontH2">20</x:Double>
    <x:Double x:Key="TcvFontBody">16</x:Double>
    <x:Double x:Key="TcvFontCaption">14</x:Double>
    <x:Double x:Key="TcvFontMicro">12</x:Double>
    <x:Double x:Key="TcvLineHeightBody">1.5</x:Double>

    <!-- Soft shadow presets (use on Border.Shadow — avoid stacking many on map) -->
    <Shadow x:Key="TcvShadowSoft" Brush="#33000000" Offset="0,2" Radius="8" Opacity="1" />
    <Shadow x:Key="TcvShadowCard" Brush="#40000000" Offset="0,4" Radius="16" Opacity="1" />
    <Shadow x:Key="TcvShadowElevated" Brush="#45000000" Offset="0,8" Radius="24" Opacity="1" />

</ResourceDictionary>
