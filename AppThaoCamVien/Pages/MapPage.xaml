<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
    x:Class="AppThaoCamVien.Pages.MapPage"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="*, Auto, Auto">

        <mapsui:MapView x:Name="ZooMap" Grid.Row="0" Grid.RowSpan="3" HorizontalOptions="Fill" VerticalOptions="Fill" />

        <Grid Grid.Row="0" VerticalOptions="Start" Padding="20,60,20,0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">

            <Border Grid.Column="0" BackgroundColor="#EEFFFFFF" Padding="12,10" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,4"/>
                </Border.Shadow>
                <ImageButton Source="icon_back_gray.png" WidthRequest="20" HeightRequest="20" BackgroundColor="Transparent" Clicked="OnBackClicked"/>
            </Border>

            <Border Grid.Column="1" BackgroundColor="#EEFFFFFF" Padding="15,10" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,4"/>
                </Border.Shadow>
                <Label Text="{DynamicResource TxtMapTitle}" TextColor="#1A1A1A" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <Border Grid.Column="2" BackgroundColor="#EEFFFFFF" Padding="12,10" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,4"/>
                </Border.Shadow>
                <ImageButton x:Name="CenterBtn" Source="icon_menu_dots_gray.png" WidthRequest="20" HeightRequest="20" BackgroundColor="Transparent" Clicked="OnCenterClicked"/>
            </Border>
        </Grid>

        <Border x:Name="GpsBadge" Grid.Row="0" BackgroundColor="#DDFFFFFF" Padding="12,6" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,130,0,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Radius="10" Offset="0,4"/>
            </Border.Shadow>
            <HorizontalStackLayout Spacing="6">
                <Ellipse x:Name="GpsDot" Fill="#28A745" WidthRequest="8" HeightRequest="8" VerticalOptions="Center"/>
                <Label x:Name="GpsLabel" Text="Đang kết nối GPS..." TextColor="#1A1A1A" FontSize="11" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Border>

        <Border Grid.Row="0" WidthRequest="50" HeightRequest="50" BackgroundColor="White" StrokeThickness="0" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,20,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.15" Radius="10" Offset="0,5"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMyLocationTapped"/>
            </Border.GestureRecognizers>
            <Label Text="📍" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             QUEUE PANEL: hiện khi đang phát POI hoặc có POI trong hàng đợi.
             Hàng trên: tên POI đang phát + nút ⏭ (Skip) + ⏹ (Stop).
             Hàng dưới: chip list các POI đang chờ (tap X để xoá khỏi queue).
             Toàn bộ panel ẩn khi không có gì phát.
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="QueuePanel" Grid.Row="1"
                IsVisible="False"
                Margin="15,0,15,8"
                Padding="0"
                BackgroundColor="White"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.15" Radius="15" Offset="0,4"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="8" Padding="12,10,10,10">
                <!-- Hàng 1: Đang phát + skip + stop -->
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="🔊" FontSize="16" VerticalOptions="Center"/>

                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                        <Label Text="ĐANG PHÁT" FontSize="9" FontAttributes="Bold" TextColor="#89d957" CharacterSpacing="2"/>
                        <Label x:Name="QueueNowPlayingLbl" Text="—" FontSize="13" FontAttributes="Bold" TextColor="#1A1A1A" LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>

                    <!-- Skip button (⏭) -->
                    <Border x:Name="QueueSkipBtn" Grid.Column="2" WidthRequest="38" HeightRequest="38"
                            BackgroundColor="#F0F9F4" StrokeThickness="0" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnQueueSkipTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="⏭" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Stop button (⏹) -->
                    <Border Grid.Column="3" WidthRequest="38" HeightRequest="38"
                            BackgroundColor="#FFECEC" StrokeThickness="0" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnQueueStopTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="⏹" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#C0392B" FontAttributes="Bold"/>
                    </Border>
                </Grid>

                <!-- Hàng 2: Tiếp theo — chỉ hiện khi queue không rỗng -->
                <Grid x:Name="QueueListRow" ColumnDefinitions="Auto,*" ColumnSpacing="8" IsVisible="False">
                    <Label Grid.Column="0" Text="Tiếp theo:" FontSize="10" FontAttributes="Bold" TextColor="#6C757D" CharacterSpacing="1" VerticalOptions="Center"/>

                    <ScrollView Grid.Column="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout x:Name="QueueChipsContainer" Spacing="6"/>
                    </ScrollView>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <controls:StateContainer Grid.Row="2"
                                 State="{Binding State}"
                                 EmptyMessage="{Binding EmptyMessage}"
                                 ErrorMessage="{Binding ErrorMessage}"
                                 RetryCommand="{Binding RetryCommand}">
            <controls:StateContainer.SuccessContent>
                <Grid>

                    <Border x:Name="NearPoiPanel" Margin="15,0,15,35" Padding="0" BackgroundColor="White" StrokeThickness="0" IsVisible="False">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#1A1A1A" Opacity="0.18" Radius="25" Offset="0,8"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto,Auto">
                            <!-- Top row: Image + Info -->
                            <Grid Grid.Row="0" ColumnDefinitions="75,*" ColumnSpacing="12" Padding="14,14,14,8">
                                <Border Grid.Column="0" WidthRequest="75" HeightRequest="75" BackgroundColor="#F0F9F4" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <Image x:Name="NearPoiImg" Source="placeholder_animal.png" Aspect="AspectFill"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                    <Label x:Name="NearPoiName" Text="..." FontSize="17" FontAttributes="Bold" TextColor="#1A1A1A" LineBreakMode="TailTruncation"/>
                                    <HorizontalStackLayout Spacing="10">
                                        <Label x:Name="NearPoiDist" Text="📍 --m" FontSize="12" TextColor="#6C757D" FontAttributes="Bold"/>
                                        <Label x:Name="NearPoiStatus" Text="● Trong vùng" FontSize="12" TextColor="#4CAF50" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Bottom row: Action buttons -->
                            <HorizontalStackLayout Grid.Row="1" Spacing="10" Padding="14,4,14,14" HorizontalOptions="Fill">
                                <Border BackgroundColor="#F5F5F5" Padding="18,0" HeightRequest="40" StrokeThickness="0" HorizontalOptions="FillAndExpand">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14"/>
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDirectionsTapped"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="🗺" FontSize="14" VerticalOptions="Center"/>
                                        <Label Text="{DynamicResource TxtDirections}" TextColor="#1A1A1A" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>

                                <Border BackgroundColor="#198754" Padding="18,0" HeightRequest="40" StrokeThickness="0" HorizontalOptions="FillAndExpand">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#198754" Opacity="0.3" Radius="8" Offset="0,3"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnListenNowTapped"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="🎧" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                                        <Label Text="{DynamicResource TxtListenBtn}" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>

                    <Border x:Name="DefaultPanel" Margin="20,0,20,40" Padding="20" BackgroundColor="#EEFFFFFF" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="25"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.15" Radius="20" Offset="0,5"/>
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{DynamicResource TxtAttractions}" FontSize="16" FontAttributes="Bold" TextColor="#1A1A1A" VerticalOptions="Center"/>
                                <Label Grid.Column="1" x:Name="PoiCountLbl" Text="0 điểm" FontSize="12" FontAttributes="Bold" TextColor="#28A745" VerticalOptions="Center"/>
                            </Grid>

                            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                <HorizontalStackLayout x:Name="ChipsContainer" Spacing="10"/>
                            </ScrollView>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </controls:StateContainer.SuccessContent>
        </controls:StateContainer>

    </Grid>
</ContentPage>