<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.AboutPage"
             BackgroundColor="{StaticResource TcvBackgroundPage}"
             Title="{DynamicResource TxtAboutApp}">
    <controls:StateContainer State="{Binding State}"
                             EmptyMessage="{Binding EmptyMessage}"
                             ErrorMessage="{Binding ErrorMessage}"
                             RetryCommand="{Binding RetryCommand}">
        <controls:StateContainer.SuccessContent>
            <ScrollView>
                <VerticalStackLayout Padding="20,24,20,20" Spacing="14">
                    <Label Text="{DynamicResource TxtAboutTitle}"
                           Style="{StaticResource TcvLabelH1}" />

                    <CollectionView ItemsSource="{Binding Sections}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TcvCardBorder}">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="{Binding Title}" Style="{StaticResource TcvLabelH2}" />
                                        <Label Text="{Binding Body}" Style="{StaticResource TcvLabelBody}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </controls:StateContainer.SuccessContent>
    </controls:StateContainer>
</ContentPage>
