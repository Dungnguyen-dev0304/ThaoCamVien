<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.AboutPage"
             BackgroundColor="#F4F7F4"
             Title="{DynamicResource TxtAboutApp}">

    <ScrollView>
        <VerticalStackLayout Padding="20,40,20,20" Spacing="25" HorizontalOptions="Center">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="15">
                <Frame HeightRequest="120" WidthRequest="120" CornerRadius="60"
                       IsClippedToBounds="True" Padding="0" HasShadow="True" BorderColor="Transparent">
                    <Frame.Shadow>
                        <Shadow Brush="Black" Offset="0,5" Radius="15" Opacity="0.2"/>
                    </Frame.Shadow>
                    <Image Source="logothaocamvien.png" Aspect="AspectFill" />
                </Frame>

                <Label Text="Smart Audio Tour" FontSize="22" FontAttributes="Bold"
                       TextColor="#2E7D32" HorizontalOptions="Center" />
                <!-- Phiên bản đổi theo ngôn ngữ -->
                <Label Text="{DynamicResource TxtAppVersion}" FontSize="14"
                       TextColor="#757575" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <Frame CornerRadius="20" BackgroundColor="White" Padding="20"
                   HasShadow="True" BorderColor="Transparent">
                <Frame.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08"/>
                </Frame.Shadow>
                <VerticalStackLayout Spacing="15">
                    <!-- Tiêu đề "Về ứng dụng" đổi theo ngôn ngữ -->
                    <Label Text="{DynamicResource TxtAboutTitle}" FontSize="18"
                           FontAttributes="Bold" TextColor="#1C1C1E" />
                    <!-- Mô tả đổi theo ngôn ngữ -->
                    <Label Text="{DynamicResource TxtAboutDesc}" FontSize="15"
                           TextColor="#424242" LineHeight="1.4" />
                    <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,10" />
                    <!-- Tên developer đổi theo ngôn ngữ -->
                    <Label Text="{DynamicResource TxtDeveloper}" FontSize="14"
                           FontAttributes="Bold" TextColor="#4CAF50" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
