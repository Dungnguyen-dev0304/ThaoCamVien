<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.HomePage"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0a2e1f" Offset="0.0" />
            <GradientStop Color="#1a5c40" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <controls:StateContainer State="{Binding State}"
                             EmptyMessage="{Binding EmptyMessage}"
                             ErrorMessage="{Binding ErrorMessage}"
                             RetryCommand="{Binding RetryCommand}">
        <controls:StateContainer.SuccessContent>
            <ScrollView VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Spacing="0">
                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,46,16,8">
                        <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                            <Image Source="splash.png" WidthRequest="34" HeightRequest="34" VerticalOptions="Center" />
                            <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding Feed.Greeting}"
                                       TextColor="White"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                                <Label Text="{DynamicResource TxtAudioGuide}"
                                       TextColor="#a5d6a7"
                                       FontSize="10"
                                       CharacterSpacing="1.5" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!-- Language toggle -->
                        <Border Grid.Column="1"
                                BackgroundColor="#1a5c40"
                                Stroke="#ffca28"
                                StrokeThickness="1"
                                Padding="10,6"
                                VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="LangLbl"
                                   Text="VI"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Weather -->
                    <Border Margin="16,0,16,0"
                            BackgroundColor="#000000"
                            Opacity="0.12"
                            Stroke="#2DBE7A"
                            StrokeThickness="1"
                            Padding="14,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{DynamicResource TxtWeatherAtZoo}" TextColor="White" FontAttributes="Bold" />
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" Text="{Binding Weather.Condition}" TextColor="#A0C8B4" FontSize="12" />
                                <Label Grid.Column="1" Text="{Binding Weather.TemperatureC, StringFormat='{0:0}°C'}" TextColor="#FFCA28" FontSize="14" FontAttributes="Bold" />
                                <Label Grid.Column="2" Text="•" TextColor="#A0C8B4" FontSize="12" VerticalTextAlignment="Center" />
                            </Grid>
                            <Label Text="{Binding Weather.Advice}" TextColor="#E8F5E9" FontSize="12" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- CTA -->
                    <Button Text="{DynamicResource TxtStartTour}"
                            Margin="16,14,16,0"
                            Clicked="OnStartClicked"
                            BackgroundColor="#FFCA28"
                            TextColor="#061F14"
                            CornerRadius="18"
                            HeightRequest="52" />

                    <!-- Now & Recommended -->
                    <VerticalStackLayout Padding="16,18,16,22" Spacing="18">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{DynamicResource TxtHappeningNow}" TextColor="White" FontAttributes="Bold" FontSize="16" />
                            <CollectionView x:Name="NowCarousel"
                                            ItemsSource="{Binding Feed.HappenNow}"
                                            SelectionMode="Single"
                                            SelectionChanged="OnNowSelectionChanged">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border WidthRequest="210"
                                                BackgroundColor="#0f3322"
                                                Stroke="#ffca28"
                                                StrokeThickness="1"
                                                Padding="0"
                                                >
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>
                                            <Grid RowDefinitions="120,*">
                                                <Image Grid.Row="0"
                                                       Source="{Binding ThumbnailUrl}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="120" />
                                                <VerticalStackLayout Grid.Row="1"
                                                                     Padding="12,10"
                                                                     Spacing="6">
                                                    <Label Text="{Binding Title}"
                                                           TextColor="White"
                                                           FontAttributes="Bold"
                                                           FontSize="14"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding Subtitle}"
                                                           TextColor="#A0C8B4"
                                                           FontSize="12"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{DynamicResource TxtListenBtn}"
                                                           TextColor="#FFCA28"
                                                           FontAttributes="Bold"
                                                           FontSize="12" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="10">
                            <Label Text="{DynamicResource TxtRecommendedForYou}" TextColor="White" FontAttributes="Bold" FontSize="16" />
                            <CollectionView x:Name="RecommendedCarousel"
                                            ItemsSource="{Binding Feed.Recommended}"
                                            SelectionMode="Single"
                                            SelectionChanged="OnRecommendedSelectionChanged">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border WidthRequest="210"
                                                BackgroundColor="#0f3322"
                                                Stroke="#ffca28"
                                                StrokeThickness="1"
                                                Padding="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16" />
                                            </Border.StrokeShape>
                                            <Grid RowDefinitions="120,*">
                                                <Image Grid.Row="0"
                                                       Source="{Binding ThumbnailUrl}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="120" />
                                                <VerticalStackLayout Grid.Row="1"
                                                                     Padding="12,10"
                                                                     Spacing="6">
                                                    <Label Text="{Binding Title}"
                                                           TextColor="White"
                                                           FontAttributes="Bold"
                                                           FontSize="14"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding Subtitle}"
                                                           TextColor="#A0C8B4"
                                                           FontSize="12"
                                                           LineBreakMode="TailTruncation" />
                                                    <Label Text="{DynamicResource TxtListenBtn}"
                                                           TextColor="#FFCA28"
                                                           FontAttributes="Bold"
                                                           FontSize="12" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </controls:StateContainer.SuccessContent>
    </controls:StateContainer>
</ContentPage>

