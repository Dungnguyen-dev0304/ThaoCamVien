<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             xmlns:vm="clr-namespace:AppThaoCamVien.ViewModels"
             x:Class="AppThaoCamVien.Pages.HomePage"
             x:DataType="vm:HomePageViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFFFFF">

    <ContentPage.Resources>
        <Color x:Key="BrandGreen">#198754</Color>
        <Color x:Key="TextMain">#1A1A1A</Color>
        <Color x:Key="TextGray">#6C757D</Color>
        <Color x:Key="BorderLight">#E9ECEF</Color>
        <Color x:Key="BadgeBg">#99000000</Color>
    </ContentPage.Resources>

    <controls:StateContainer State="{Binding State}"
                             EmptyMessage="{Binding EmptyMessage}"
                             ErrorMessage="{Binding ErrorMessage}"
                             RetryCommand="{Binding RetryCommand}">

        <controls:StateContainer.SuccessContent>
            <Grid RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
                    <VerticalStackLayout Padding="20,50,20,20" Spacing="25">

                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10" VerticalOptions="Start">
                            <Border WidthRequest="100" 
                                    HeightRequest="100" 
                                    BackgroundColor="White"
                                    Stroke="{StaticResource BorderLight}" 
                                    StrokeThickness="2" 
                                    HorizontalOptions="Center" 
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="50" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.1" Radius="15" Offset="0,5" />
                                </Border.Shadow>
                                <Image Source="logothaocamvien.png" 
                                       Aspect="AspectFill" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" />
                            </Border>

                            <Border Grid.Column="1" 
                                    BackgroundColor="White" 
                                    Stroke="{StaticResource BorderLight}" 
                                    StrokeThickness="1" 
                                    Padding="4" 
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLangTapped" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label x:Name="LangLbl" 
                                           Text="VN" 
                                           TextColor="{StaticResource BrandGreen}" 
                                           FontAttributes="Bold" 
                                           FontSize="13" 
                                           VerticalOptions="Center" />
                                    <Label Text="EN" 
                                           TextColor="{StaticResource TextGray}" 
                                           FontAttributes="Bold" 
                                           FontSize="13" 
                                           VerticalOptions="Center" 
                                           Margin="0,0,8,0"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                        <Border BackgroundColor="White" Stroke="{StaticResource BorderLight}" StrokeThickness="1" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#F0F4F8" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="25" />
                                    </Border.StrokeShape>
                                    <Label Text="🕒" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#4285F4"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0" Spacing="2">
                                    <Label Text="Thảo Cầm Viên" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource BrandGreen}"/>
                                    <Label FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextMain}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{DynamicResource TxtOpenHours}" />
                                                <Span Text=": 07:00 - 18:30" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Border BackgroundColor="{StaticResource BrandGreen}" StrokeThickness="0" Padding="25">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource BrandGreen}" Opacity="0.3" Radius="15" Offset="0,8" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="{DynamicResource TxtHi}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                                <Label Text="{DynamicResource TxtAnimalDesc}" TextColor="#E8F5E9" FontSize="13" LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{DynamicResource TxtDiscoveries}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextMain}"/>

                                <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <HorizontalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnViewAllTapped" />
                                    </HorizontalStackLayout.GestureRecognizers>
                                    <Label Text="{DynamicResource TxtViewAll}" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" FontSize="14" />
                                    <Label Text=">" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" FontSize="14" />
                                </HorizontalStackLayout>
                            </Grid>

                            <CollectionView x:Name="NearbyPlacesView"
                                            HeightRequest="220"
                                            ItemsSource="{Binding NearbyPlaces}"
                                            SelectionMode="Single"
                                            SelectionChanged="OnNearbySelectionChanged"
                                            HorizontalScrollBarVisibility="Never">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NearbyPlaceCard">
                                        <Border WidthRequest="155"
                                                HeightRequest="210"
                                                BackgroundColor="White"
                                                StrokeThickness="0"
                                                Margin="2">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="20" />
                                            </Border.StrokeShape>
                                            <Border.Shadow>
                                                <Shadow Brush="#1A1A1A" Opacity="0.08" Radius="12" Offset="0,6" />
                                            </Border.Shadow>

                                            <Grid RowDefinitions="130, *">
                                                <!-- Animal Image with rounded top -->
                                                <Grid Grid.Row="0">
                                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="130" />
                                                    <!-- Gradient overlay at bottom of image -->
                                                    <BoxView VerticalOptions="End" HeightRequest="40" Opacity="0.3" BackgroundColor="Black" />
                                                </Grid>

                                                <!-- Category badge -->
                                                <Border BackgroundColor="{StaticResource BrandGreen}"
                                                        HorizontalOptions="Start"
                                                        VerticalOptions="Start"
                                                        Margin="10"
                                                        Padding="8,3"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8" />
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding DistanceLabel, FallbackValue='🐾'}"
                                                           TextColor="White"
                                                           FontSize="9"
                                                           FontAttributes="Bold" />
                                                </Border>

                                                <!-- Rating badge on image -->
                                                <Border BackgroundColor="#DDFFFFFF"
                                                        HorizontalOptions="End"
                                                        VerticalOptions="Start"
                                                        Margin="10"
                                                        Padding="6,3"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8" />
                                                    </Border.StrokeShape>
                                                    <Label Text="⭐ 4.9" FontSize="9" TextColor="{StaticResource TextMain}" FontAttributes="Bold" />
                                                </Border>

                                                <!-- Info section -->
                                                <VerticalStackLayout Grid.Row="1" Padding="10,8,10,10" Spacing="3" VerticalOptions="Center">
                                                    <Label Text="{Binding Title}"
                                                           FontAttributes="Bold"
                                                           FontSize="14"
                                                           TextColor="{StaticResource TextMain}"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="📍" FontSize="10" TextColor="{StaticResource TextGray}" VerticalTextAlignment="Center"/>
                                                        <Label Text="{Binding LocationHint}" FontSize="11" TextColor="{StaticResource TextGray}" LineBreakMode="TailTruncation" VerticalTextAlignment="Center" MaxLines="1"/>
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </controls:StateContainer.SuccessContent>
    </controls:StateContainer>
</ContentPage>
