<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.HomePage"
             BackgroundColor="#F4F7F4"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <Grid RowDefinitions="220, *">

            <!-- Hero gradient header -->
            <Grid Grid.Row="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#4CAF50" Offset="0.0"/>
                        <GradientStop Color="#2E7D32" Offset="1.0"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <VerticalStackLayout Padding="24,55,24,0" Spacing="6">
                    <Label Text="Xin chào 👋"
                           TextColor="#E8F5E9" FontSize="17"/>
                    <Label Text="Khám phá Thảo Cầm Viên"
                           TextColor="White" FontSize="26" FontAttributes="Bold"/>
                    <Label Text="Hành trình âm thanh thông minh"
                           TextColor="#C8E6C9" FontSize="14"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Cards -->
            <Grid Grid.Row="1" Margin="20,-45,20,20"
                  RowDefinitions="Auto, Auto" RowSpacing="16">

                <!-- Card Bản đồ (lớn) -->
                <Border Grid.Row="0" BackgroundColor="White"
                        Stroke="Transparent" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,6" Radius="16" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid ColumnDefinitions="*, Auto" Padding="22,18">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenMapClicked"/>
                        </Grid.GestureRecognizers>
                        <VerticalStackLayout Grid.Column="0"
                                             VerticalOptions="Center" Spacing="4">
                            <Label Text="🗺 Sơ đồ sở thú"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#1C1C1E"/>
                            <Label Text="Định vị GPS · Thuyết minh tự động"
                                   FontSize="13" TextColor="#757575"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1"
                                HeightRequest="58" WidthRequest="58"
                                BackgroundColor="#E8F5E9"
                                Stroke="Transparent" Padding="14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="29"/>
                            </Border.StrokeShape>
                            <Image Source="map_white.png" Aspect="AspectFit"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 2 card nhỏ: QR và Numpad -->
                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="14">

                    <!-- QR Card -->
                    <Border Grid.Column="0" BackgroundColor="White"
                            Stroke="Transparent" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Padding="20,22"
                                             HorizontalOptions="Center" Spacing="12">
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenQrClicked"/>
                            </VerticalStackLayout.GestureRecognizers>
                            <Border HeightRequest="52" WidthRequest="52"
                                    BackgroundColor="#FFF3E0"
                                    Stroke="Transparent" Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Image Source="qr_white.png" Aspect="AspectFit"/>
                            </Border>
                            <Label Text="Quét QR"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#1C1C1E"
                                   HorizontalOptions="Center"/>
                            <Label Text="Hướng camera vào biển báo"
                                   FontSize="11" TextColor="#9E9E9E"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Numpad Card -->
                    <Border Grid.Column="1" BackgroundColor="White"
                            Stroke="Transparent" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout Padding="20,22"
                                             HorizontalOptions="Center" Spacing="12">
                            <VerticalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOpenNumpadClicked"/>
                            </VerticalStackLayout.GestureRecognizers>
                            <Border HeightRequest="52" WidthRequest="52"
                                    BackgroundColor="#E3F2FD"
                                    Stroke="Transparent" Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="26"/>
                                </Border.StrokeShape>
                                <Image Source="numpad_white.png" Aspect="AspectFit"/>
                            </Border>
                            <Label Text="Nhập Mã"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#1C1C1E"
                                   HorizontalOptions="Center"/>
                            <Label Text="Nhập số trên biển báo"
                                   FontSize="11" TextColor="#9E9E9E"
                                   HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
