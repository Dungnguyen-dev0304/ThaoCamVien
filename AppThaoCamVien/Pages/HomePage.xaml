<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.HomePage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#FFFFFF">
    <ContentPage.Resources>
        <Color x:Key="BrandGreen">#198754</Color>
        <Color x:Key="TextMain">#1A1A1A</Color>
        <Color x:Key="TextGray">#6C757D</Color>
        <Color x:Key="BorderLight">#E9ECEF</Color>
        <Color x:Key="BgLight">#F8F9FA</Color>
    </ContentPage.Resources>

    <controls:StateContainer State="{Binding State}"
                             EmptyMessage="{Binding EmptyMessage}"
                             ErrorMessage="{Binding ErrorMessage}"
                             RetryCommand="{Binding RetryCommand}">
        <controls:StateContainer.SuccessContent>

            <Grid RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never" >
                    <VerticalStackLayout Padding="20,50,20,20" Spacing="25">

                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10" VerticalOptions="Start">
                            <Border WidthRequest="100" 
        HeightRequest="100" 
        BackgroundColor="White"
        Stroke="{StaticResource BorderLight}" 
        StrokeThickness="2" 
        HorizontalOptions="Center" 
        VerticalOptions="Center">
    
    <Border.StrokeShape>
        <RoundRectangle CornerRadius="50" />
    </Border.StrokeShape>
    
    <Image Source="logothaocamvien.png" 
           Aspect="AspectFill" 
           HorizontalOptions="Center" 
           VerticalOptions="Center" />
</Border>

                            <Border Grid.Column="2" BackgroundColor="White" Stroke="{StaticResource BorderLight}" StrokeThickness="1" Padding="4" VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnLangTapped" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    

                                    <Label x:Name="LangLbl" 
                                           Text="VN" 
                                           TextColor="{StaticResource BrandGreen}" 
                                           FontAttributes="Bold" 
                                           FontSize="13"
                                           VerticalOptions="Center" />

                                    <Label Text="EN" 
                                           TextColor="{StaticResource TextGray}" 
                                           FontAttributes="Bold" 
                                           FontSize="13"
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                       <!-- <Border BackgroundColor="#FFF3CD" StrokeThickness="0" Padding="15" IsVisible="{Binding IsOffline}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                <Label Text="⚡" FontSize="16" VerticalTextAlignment="Center" />
                                <Label Grid.Column="1" Text="{Binding OfflineMessage}" FontSize="13" TextColor="#856404" LineBreakMode="TailTruncation" />
                            </Grid>
                        </Border> -->

                        <Border BackgroundColor="White" Stroke="{StaticResource BorderLight}" StrokeThickness="1" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Border WidthRequest="50" HeightRequest="50" BackgroundColor="#F0F4F8" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="25" />
                                    </Border.StrokeShape>
                                    <Label Text="🕒" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#4285F4"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0,0,0" Spacing="2">
                                    <Label Text="Thảo Cầm Viên" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Primary}"/>
                                    <Label FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextMain}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{DynamicResource TxtOpenHours}" />

                                                <Span Text=": 07:00 - 18:30" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                       <!-- <Border BackgroundColor="White" Stroke="{StaticResource BorderLight}" StrokeThickness="1" Padding="15,5">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *">
                                <Label Text="🔍" FontSize="18" TextColor="{StaticResource TextGray}" VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Entry Grid.Column="1" Placeholder="Tìm kiếm động vật, di tích..." TextColor="{StaticResource TextMain}" BackgroundColor="Transparent"/>
                            </Grid>
                        </Border> -->

                        <Border BackgroundColor="{StaticResource BrandGreen}" StrokeThickness="0" Padding="25">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource BrandGreen}" Opacity="0.3" Radius="15" Offset="0,8" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                    

                                    <Label Text="{DynamicResource TxtHi}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                                    <Label Text="{DynamicResource TxtAnimalDesc}" TextColor="#E8F5E9" FontSize="13" LineBreakMode="WordWrap" Margin="0,0,10,0"/>

                                   
                                </VerticalStackLayout>

                                
                            </Grid>
                        </Border> 

                        <VerticalStackLayout Spacing="15">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{DynamicResource TxtDiscoveries}" 
           FontSize="20" 
           FontAttributes="Bold" 
           TextColor="{StaticResource TextMain}"/>

                                <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                    <HorizontalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnViewAllTapped" />
                                    </HorizontalStackLayout.GestureRecognizers>

                                    <Label Text="{DynamicResource TxtViewAll}" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" FontSize="14" />
                                    <Label Text=">" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" FontSize="14" />
                                </HorizontalStackLayout>
                            </Grid>

                            <CollectionView x:Name="NearbyPlacesView"
                                            ItemsSource="{Binding NearbyPlaces}"
                                            SelectionMode="Single"
                                            SelectionChanged="OnNearbySelectionChanged"
                                            HorizontalScrollBarVisibility="Never">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border WidthRequest="220" StrokeThickness="1" Stroke="{StaticResource BorderLight}" BackgroundColor="White" Padding="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="24" />
                                            </Border.StrokeShape>

                                            <Grid RowDefinitions="180, Auto">
                                                <Image Grid.Row="0" Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                                <Border Grid.Row="0" BackgroundColor="#99000000" Padding="10,5" Margin="15" HorizontalOptions="Start" VerticalOptions="Start" StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="12" />
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding DistanceLabel, FallbackValue='Thú'}" FontSize="11" TextColor="White" FontAttributes="Bold" />
                                                </Border>

                                                <Border Grid.Row="0" BackgroundColor="White" Padding="8,4" Margin="15" HorizontalOptions="End" VerticalOptions="End" StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="10" />
                                                    </Border.StrokeShape>
                                                    <Label Text="⭐ 4.9" FontSize="11" TextColor="{StaticResource TextMain}" FontAttributes="Bold" />
                                                </Border>

                                                <VerticalStackLayout Grid.Row="1" BackgroundColor="White" Padding="15">
                                                    <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource TextMain}" LineBreakMode="TailTruncation" />
                                                    <Label Text="{Binding LocationHint}" FontSize="12" TextColor="{StaticResource TextGray}" LineBreakMode="TailTruncation" Margin="0,4,0,0"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="15" Margin="0,0,0,30">
                            <Label Text="{Binding StartTourTitle}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextMain}" />
                            <Border StrokeThickness="0" BackgroundColor="Transparent" Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="24" />
                                </Border.StrokeShape>
                                <Grid HeightRequest="120">
                                    <Image Source="{Binding StartTourBackgroundImageUrl}" Aspect="AspectFill" />
                                    <BoxView>
                                        <BoxView.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0.0" />
                                                <GradientStop Color="#AA000000" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </BoxView.Background>
                                    </BoxView>
                                    <Button Text="{Binding StartTourButtonText}" Clicked="OnStartClicked" BackgroundColor="{StaticResource BrandGreen}" TextColor="White" CornerRadius="15" HeightRequest="45" FontAttributes="Bold" Margin="15" HorizontalOptions="Fill" VerticalOptions="End" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

               
            </Grid>
        </controls:StateContainer.SuccessContent>
    </controls:StateContainer>
</ContentPage>