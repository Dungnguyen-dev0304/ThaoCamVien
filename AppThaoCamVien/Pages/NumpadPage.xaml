<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.NumpadPage"
             BackgroundColor="#F4F7F4"
             Title="{DynamicResource TxtNumpadTitle}">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20,50,20,30">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,20">
            <ImageButton Grid.Column="0" Source="icon_back_dark.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent" Clicked="OnBackClicked"/>
            <!-- Tiêu đề đổi theo ngôn ngữ -->
            <Label Grid.Column="1" Text="{DynamicResource TxtNumpadTitle}"
                   FontSize="20" FontAttributes="Bold" TextColor="#1C1C1E"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <VerticalStackLayout Grid.Row="1" Spacing="8" HorizontalOptions="Center" Margin="0,10,0,40">
            <!-- Hướng dẫn đổi theo ngôn ngữ -->
            <Label Text="{DynamicResource TxtNumpadInstruction}" FontSize="14"
                   TextColor="#757575" HorizontalOptions="Center"/>

            <Border BackgroundColor="White" Padding="20,15" Stroke="#E0E0E0" StrokeThickness="2"
                    MinimumWidthRequest="200" HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,3" Radius="8" Opacity="0.08"/>
                </Border.Shadow>
                <Label x:Name="CodeDisplay" Text="_ _ _" FontSize="42" FontAttributes="Bold"
                       TextColor="#2E7D32" HorizontalOptions="Center" CharacterSpacing="8"/>
            </Border>

            <Label x:Name="ErrorLabel" Text="" FontSize="13" TextColor="#E53935"
                   HorizontalOptions="Center" IsVisible="False"/>
        </VerticalStackLayout>

        <!-- Bàn phím số — không cần dịch vì là số -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*,*" RowDefinitions="*,*,*,*"
              ColumnSpacing="16" RowSpacing="16" HorizontalOptions="Center"
              VerticalOptions="End" MaximumWidthRequest="320">

            <Button Grid.Row="0" Grid.Column="0" Text="1" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="0" Grid.Column="1" Text="2" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="0" Grid.Column="2" Text="3" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="0" Text="4" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="1" Text="5" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="1" Grid.Column="2" Text="6" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="0" Text="7" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="1" Text="8" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="2" Grid.Column="2" Text="9" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>

            <ImageButton Grid.Row="3" Grid.Column="0" Source="icon_backspace.png"
                         BackgroundColor="Transparent" HeightRequest="80" WidthRequest="80"
                         Clicked="OnBackspaceClicked"/>
            <Button Grid.Row="3" Grid.Column="1" Text="0" FontSize="26" FontAttributes="Bold" BackgroundColor="White" TextColor="#1C1C1E" CornerRadius="40" HeightRequest="80" WidthRequest="80" Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}" Clicked="OnNumberClicked"/>
            <Button Grid.Row="3" Grid.Column="2" Text="OK" FontSize="20" FontAttributes="Bold"
                    BackgroundColor="#4CAF50" TextColor="White" CornerRadius="40"
                    HeightRequest="80" WidthRequest="80" Clicked="OnConfirmClicked">
                <Button.Shadow>
                    <Shadow Brush="#2E7D32" Offset="0,4" Radius="5" Opacity="0.35"/>
                </Button.Shadow>
            </Button>
        </Grid>
    </Grid>
</ContentPage>
