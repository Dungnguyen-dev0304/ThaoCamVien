<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.AnimalsPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <ContentPage.Resources>
        <Color x:Key="Forest900">#071B12</Color>
        <Color x:Key="Forest800">#0A2A1B</Color>
        <Color x:Key="Forest700">#0F3A26</Color>
        <Color x:Key="Forest600">#145534</Color>
        <Color x:Key="Forest500">#1C6B43</Color>
        <Color x:Key="TextPrimary">#1A1A1A</Color>
        <Color x:Key="TextMuted">#6C757D</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="300, *">

        <BoxView Grid.Row="0" 
         Color="#95D951" />

        <BoxView Grid.Row="0" BackgroundColor="Black" Opacity="0.3" />

        <VerticalStackLayout Grid.Row="0" Margin="25,50,0,35">
            <Label Text="{DynamicResource TxtStory}"    
                   FontSize="34" 
                   FontAttributes="Bold" 
                   TextColor="White" />
            <Label Text="{DynamicResource TxtDiscover}" 
                   FontSize="16" 
                   TextColor="#F8F9FA" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                Margin="0,-40,0,0"
                BackgroundColor="White"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="30,30,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="15" Opacity="0.1" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto, Auto, *" Padding="20,25,20,0">

                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Filters}"
                                SelectionMode="None" 
                                SelectedItem="{Binding SelectedFilter}"
                                HorizontalScrollBarVisibility="Never"
                                Margin="0,0,0,20"
                                HeightRequest="45">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="20,0" 
                                    BackgroundColor="#F0F9F4" 
                                    Stroke="#D1E7DD" 
                                    StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>

                                <Label Text="{Binding Title}" FontSize="13" FontAttributes="Bold" TextColor="#198754" VerticalOptions="Center"/>

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#198754" />
                                        <Setter Property="Stroke" Value="#198754" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Border.Resources>
                                    <Style TargetType="Label">
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Resources>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectCommand}" />
                                </Border.GestureRecognizers>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <CollectionView Grid.Row="2"
                x:Name="AnimalsCollectionView"
                ItemsSource="{Binding VisibleAnimals}"
                SelectionMode="Single"
                SelectionChanged="OnAnimalsSelectionChanged"
                VerticalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="15"
                                         VerticalItemSpacing="15" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0" 
            BackgroundColor="White" 
            Margin="10,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#1A1A1A" Offset="0,8" Radius="20" Opacity="0.06" />
                                </Border.Shadow>

                                <Grid RowDefinitions="160,Auto">

                                    <Grid Grid.Row="0">
                                        <Image Source="{Binding ImageUrl}" 
                       Aspect="AspectFill" />
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1" Padding="16,16,16,20" Spacing="4">

                                        <Border HorizontalOptions="Start"
                        Padding="10,4"
                        Margin="0,0,0,4"
                        StrokeThickness="0"
                        BackgroundColor="{Binding StatusColor}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding ConservationStatus}"
                           TextColor="White"
                           FontSize="10"
                           FontAttributes="Bold"
                           TextTransform="Uppercase"
                           CharacterSpacing="0.5" />
                                        </Border>

                                        <Label Text="{Binding Name}"
                       TextColor="#111827" 
                       FontAttributes="Bold"
                       FontSize="18"
                       LineBreakMode="TailTruncation" />

                                        <Label Text="{Binding Category}"
                       TextColor="#6B7280" 
                       FontSize="13"
                       LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Grid Grid.Row="0"
              Grid.RowSpan="2"
              IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              ZIndex="10">
            <ActivityIndicator IsRunning="True"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Color="#198754" />
        </Grid>

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                IsVisible="{Binding HasError}"
                BackgroundColor="White"
                Padding="25"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                ZIndex="11"
                WidthRequest="320"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="25" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.15" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="15">
                <Label Text="⚠️"
                       HorizontalOptions="Center"
                       FontSize="40" />
                <Label Text="{Binding ErrorMessage}"
                       HorizontalTextAlignment="Center"
                       TextColor="#1A1A1A"
                       FontSize="15" />
                <Button Text="{Binding RetryText}"
                        Command="{Binding LoadCommand}"
                        BackgroundColor="#1A1A1A"
                        TextColor="White"
                        CornerRadius="15"
                        HeightRequest="50"
                        FontAttributes="Bold"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>