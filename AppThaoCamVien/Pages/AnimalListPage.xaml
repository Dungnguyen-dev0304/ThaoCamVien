<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SharedThaoCamVien.Models;assembly=SharedThaoCamVien"
             x:Class="AppThaoCamVien.Pages.AnimalListPage"
             BackgroundColor="#F8F9FA"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Color x:Key="BrandGreen">#198754</Color>
        <Color x:Key="TextMain">#1A1A1A</Color>
        <Color x:Key="TextGray">#6C757D</Color>
        <Color x:Key="BorderLight">#E9ECEF</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *">

         <Entry x:Name="SearchEntry" IsVisible="False" />

         <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,60,20,15">
            <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                <Label Text="{DynamicResource TxtAnimalKingdom}" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource TextMain}" />
                <Label Text="{DynamicResource TxtAnimalDesc}" FontSize="14" TextColor="{StaticResource TextGray}" />
            </VerticalStackLayout>

            <Border Grid.Column="1" BackgroundColor="White" Stroke="{StaticResource BorderLight}" StrokeThickness="1" Padding="4" VerticalOptions="Start" Margin="0,5,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center" Padding="4,0">
                    <Label Text="VN" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                    <Label Text="EN" TextColor="#ADB5BD" FontAttributes="Bold" FontSize="12" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid> 

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Filters}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedFilter}"
                        HorizontalScrollBarVisibility="Never"
                        HeightRequest="45"
                        Margin="0,5,0,15">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.Header>
                <ContentView WidthRequest="20" />
            </CollectionView.Header>
            <CollectionView.Footer>
                <ContentView WidthRequest="20" />
            </CollectionView.Footer>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="20,8" BackgroundColor="White" Stroke="{StaticResource BorderLight}" StrokeThickness="1" VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextGray}" VerticalOptions="Center"/>

                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource BrandGreen}" />
                                <Setter Property="Stroke" Value="{StaticResource BrandGreen}" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.Resources>
                            <Style TargetType="Label">
                                <Style.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Resources>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <CollectionView Grid.Row="2" x:Name="AnimalsCollectionView" Margin="20,0,20,0" VerticalScrollBarVisibility="Never">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Poi">
                    <Border Stroke="{StaticResource BorderLight}" StrokeThickness="1" BackgroundColor="White" Padding="0" HeightRequest="140">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="30" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.05" Radius="15" Offset="0,5" />
                        </Border.Shadow>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAnimalTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="140, *">
                            <Grid Grid.Column="0">
                                <Image Source="{Binding ImageThumbnail}" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill" />
                                <Border HorizontalOptions="Start" VerticalOptions="Start" BackgroundColor="White" Padding="8,4" Margin="12" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10" />
                                    </Border.StrokeShape>
                                    <Label Text="⭐ 4.9" FontSize="11" TextColor="{StaticResource TextMain}" FontAttributes="Bold" />
                                </Border>
                            </Grid>

                            <VerticalStackLayout Grid.Column="1" Padding="15" VerticalOptions="Center" Spacing="6">
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextMain}" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Description}" FontSize="13" TextColor="{StaticResource TextGray}" MaxLines="2" LineBreakMode="TailTruncation" LineHeight="1.2"/>

                                <Grid ColumnDefinitions="Auto, *" Margin="0,10,0,0">
                                    <Border Grid.Column="0" BackgroundColor="#E8F5E9" Padding="10,5" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Label Text="Thú ăn thịt" FontSize="11" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" />
                                    </Border>
                                    <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="5">
                                        <Label Text="🔊" FontSize="12" TextColor="{StaticResource TextGray}" />
                                        <Label Text="03:45" FontSize="11" TextColor="{StaticResource TextGray}" FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>