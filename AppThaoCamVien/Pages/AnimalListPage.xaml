<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SharedThaoCamVien.Models;assembly=SharedThaoCamVien"
             x:Class="AppThaoCamVien.Pages.AnimalListPage"
             BackgroundColor="#061F14"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- 1. Header & Nút Back -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="20,50,20,10">
            <ImageButton Grid.Column="0" Source="icon_back_white.png" WidthRequest="32" HeightRequest="32" BackgroundColor="Transparent" Clicked="OnBackClicked"/>
            <Label Grid.Column="1" Text="Thảo Cầm Viên" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="White" CharacterSpacing="1"/>
            <ImageButton Grid.Column="2" Source="icon_menu_dots_white.png" WidthRequest="32" HeightRequest="32" BackgroundColor="Transparent"/>
        </Grid>

        <!-- 2. Tiêu đề chính & Thanh tìm kiếm -->
        <VerticalStackLayout Grid.Row="1" Padding="20,10,20,20" Spacing="15">
            <!-- Tiêu đề -->
            <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                <Label Text="🌿 Vương quốc động vật" FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label Text="Khám phá thế giới muôn loài tuyệt đẹp tại Thảo Cầm Viên" FontSize="12" TextColor="#A0C8B4" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="4" WidthRequest="4" CornerRadius="2" BackgroundColor="#D32F2F" HorizontalOptions="Center"/>

            <!-- Thanh Tìm kiếm -->
            <Border BackgroundColor="White" HeightRequest="46" StrokeThickness="0" Margin="0,10,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto, *">
                    <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center" Margin="15,0,5,0"/>
                    <Entry Grid.Column="1" x:Name="SearchEntry" Placeholder="Tìm kiếm động vật..." TextColor="#333333" PlaceholderColor="#999999" BackgroundColor="Transparent" VerticalOptions="Center"/>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- 3. Danh sách lưới (Grid 2 cột) -->
        <CollectionView Grid.Row="2" x:Name="AnimalsCollectionView" Margin="15,0,15,0">
            <!-- Chia làm 2 cột, khoảng cách 10 -->
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Poi">

                    <!-- Thẻ Động vật -->
                    <Border BackgroundColor="#0A2A1B" Padding="12" Stroke="#15402A" StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <!-- Gắn sự kiện nhấn vào Card truyền nguyên object Poi sang -->
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAnimalTapped" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>

                        <VerticalStackLayout Spacing="6">
                            <!-- Ảnh Thumbnail -->
                            <Image Source="{Binding ImageThumbnail}" HeightRequest="60" Aspect="AspectFit" HorizontalOptions="Center" Margin="0,10,0,15"/>

                            <!-- Tên & Tên Khoa học -->
                            <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding Description}" FontSize="10" TextColor="#A0C8B4" LineBreakMode="TailTruncation" MaxLines="1"/>

                            <!-- Mô tả ngắn (Thay bằng Description tạm) -->
                            <Label Text="{Binding Description}" FontSize="11" TextColor="#D0E8DB" Opacity="0.8" LineBreakMode="TailTruncation" MaxLines="2" Margin="0,4,0,8" HeightRequest="32"/>

                            <!-- Badges (Ví dụ hiển thị mã POI và một tag cứng) -->
                            <FlexLayout Wrap="Wrap" AlignContent="Start" JustifyContent="Start">
                                <Border BackgroundColor="#2E7D32" Padding="6,2" Margin="0,0,5,5" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4"/>
                                    </Border.StrokeShape>
                                    <Label Text="Thú" TextColor="White" FontSize="9" FontAttributes="Bold"/>
                                </Border>
                                <Border BackgroundColor="#D32F2F" Padding="6,2" Margin="0,0,5,5" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4"/>
                                    </Border.StrokeShape>
                                    <Label Text="Nguy cấp" TextColor="White" FontSize="9" FontAttributes="Bold"/>
                                </Border>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>