<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.StoryAudioPage"
             BackgroundColor="White" 
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Color x:Key="BrandGreen">#28A745</Color>
        <Color x:Key="TextMain">#1A1A1A</Color>
        <Color x:Key="TextGray">#6C757D</Color>
        <Color x:Key="BorderLight">#E9ECEF</Color>
    </ContentPage.Resources>

    <Grid>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid RowDefinitions="400, Auto">

                <Image Grid.Row="0" x:Name="PoiImage" Source="placeholder_animal.png" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill" />

                <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Margin="0,-40,0,0" Padding="25,30,25,40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="35,35,0,0" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">
                        <BoxView HeightRequest="5" WidthRequest="40" Color="{StaticResource BorderLight}" CornerRadius="2.5" HorizontalOptions="Center" Margin="0,-15,0,10" />

                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label x:Name="PoiNameLabel" Text="Hổ Đông Dương" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextMain}" />
                                <Label x:Name="PoiSubtitleLabel" Text="Panthera tigris corbetti" FontSize="13" TextColor="{StaticResource TextGray}" FontAttributes="Italic" Margin="0,2,0,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        

                        <Border BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="{StaticResource BorderLight}" Padding="20" Margin="0,15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="25">
                                <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="🔊" FontSize="16" TextColor="#6C757D" VerticalOptions="Center" />
                                        <Label Text="{DynamicResource TxtAutomatic}" FontSize="13" TextColor="#6C757D" FontAttributes="Bold" VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="{StaticResource BrandGreen}" HeightRequest="20"/>

                                    <Slider x:Name="ProgressSlider" 
                                            Minimum="0" Maximum="100" Value="30" 
                                            MinimumTrackColor="#3FA34D" 
                                            MaximumTrackColor="#E0E5E0" 
                                            ThumbColor="Transparent" 
                                            DragCompleted="OnSliderDragCompleted" 
                                            Margin="0,5,0,0"/>

                                    <Grid ColumnDefinitions="*, *">
                                        <Label x:Name="CurrentTimeLabel" Grid.Column="0" Text="01:12" FontSize="12" TextColor="#4A5568" FontAttributes="Bold" HorizontalOptions="Start"/>
                                        <Label x:Name="TotalTimeLabel" Grid.Column="1" Text="03:45" FontSize="12" TextColor="#4A5568" FontAttributes="Bold" HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- Queue UX: khi user di chuyển sang POI khác trong lúc đang phát -->
                                    <Border x:Name="QueueHintPanel"
                                            IsVisible="False"
                                            BackgroundColor="#EEF6FF"
                                            StrokeThickness="1"
                                            Stroke="#D6E8FF"
                                            Padding="12,10"
                                            Margin="0,8,0,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="Tiếp theo" FontSize="11" TextColor="#2F5D9B" FontAttributes="Bold" />
                                                <Label x:Name="QueueNextPoiLabel"
                                                       Text="—"
                                                       FontSize="13"
                                                       TextColor="#1A1A1A"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    x:Name="QueueSkipBtn"
                                                    BackgroundColor="#1E5631"
                                                    Padding="12,8"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnQueueSkipTapped" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                    <Label Text="Skip" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                                                    <Label Text="⏭" TextColor="White" FontSize="12" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>

                                <Border Grid.Column="1" WidthRequest="65" HeightRequest="65" BackgroundColor="#1E5631" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="32.5" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#1E5631" Offset="0,4" Radius="10" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayPauseClicked" />
                                    </Border.GestureRecognizers>

                                    <Image x:Name="PlayPauseIcon" Source="icon_play_white.png" Aspect="AspectFit" Margin="22,20,18,20" />
                                </Border>
                            </Grid>
                        </Border>

                        <Label Text="{DynamicResource TxtAboutApp}" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextMain}" Margin="1" />

                        <!-- <Label x:Name="ShortIntroLabel" FontSize="15" TextColor="{StaticResource TextGray}" LineHeight="1.6" Margin="0,0,0,10"/> -->

                        <Label x:Name="PoiDescTitleLabel" Text="Chi tiết sinh học" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextMain}" IsVisible="False"/>
                        <Label x:Name="PoiDescLabel" FontSize="14" TextColor="{StaticResource TextGray}" LineHeight="1.6"/>

                        <Button Text="{DynamicResource TxtDirections}"
                                Clicked="OnNavigateToPoiClicked"
                                BackgroundColor="#111625"
                                TextColor="White"
                                CornerRadius="15"
                                HeightRequest="55"
                                FontAttributes="Bold"
                                Margin="0,20,0,30" />

                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <Border WidthRequest="45" HeightRequest="45" BackgroundColor="#80000000" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Start" Margin="20,50">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22.5" />
            </Border.StrokeShape>
            <ImageButton Source="icon_back_white.png" WidthRequest="20" HeightRequest="20" BackgroundColor="Transparent" Clicked="OnBackClicked" />
        </Border>

        <!-- ──────────────────────────────────────────────────────────────
             PREMIUM GATE — Apple Museum Gallery aesthetic
             Edge-to-edge parchment canvas. Hero typography. Single Action Blue.
             No shadows on chrome. Hairline borders only.
        ────────────────────────────────────────────────────────────────── -->
        <Grid x:Name="PremiumGateOverlay"
              IsVisible="False"
              BackgroundColor="#f5f5f7">

            <ScrollView VerticalScrollBarVisibility="Never">
                <VerticalStackLayout Padding="0,72,0,40" Spacing="0">

                    <!-- Eyebrow tag -->
                    <Label Text="THẢO CẦM VIÊN · PREMIUM"
                           TextColor="#7a7a7a"
                           FontSize="11"
                           CharacterSpacing="3.5"
                           HorizontalOptions="Center"
                           Margin="0,0,0,32"/>

                    <!-- Hero icon — single Action Blue circle, no shadow -->
                    <Border WidthRequest="92" HeightRequest="92"
                            BackgroundColor="#0066cc"
                            StrokeThickness="0"
                            HorizontalOptions="Center"
                            Margin="0,0,0,40">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="46"/>
                        </Border.StrokeShape>
                        <Label Text="◈"
                               FontSize="42"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Hero headline (display-md 34px / 600 / -0.374) -->
                    <Label x:Name="GatePoiNameLabel"
                           Text="—"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="#1d1d1f"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Padding="32,0"
                           LineBreakMode="WordWrap"/>

                    <!-- Lead subcopy (lead 28px / 400 — but slightly smaller for gate) -->
                    <Label Text="Câu chuyện chuyên sâu, bản thuyết minh chuyên nghiệp"
                           FontSize="17"
                           TextColor="#7a7a7a"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Padding="40,12,40,0"
                           LineHeight="1.47"/>

                    <!-- Massive price (hero-display proportions) -->
                    <Label x:Name="GatePriceLabel"
                           Text="50.000 ₫"
                           FontSize="56"
                           FontAttributes="Bold"
                           TextColor="#0066cc"
                           HorizontalOptions="Center"
                           Margin="0,40,0,4"
                           CharacterSpacing="-1"/>

                    <Label Text="Một lần mua · Truy cập vĩnh viễn"
                           FontSize="13"
                           TextColor="#7a7a7a"
                           HorizontalOptions="Center"
                           CharacterSpacing="0.5"
                           Margin="0,0,0,48"/>

                    <!-- Benefit card (white surface, 1px hairline, rounded.lg=18) -->
                    <Border BackgroundColor="White"
                            Stroke="#e0e0e0"
                            StrokeThickness="1"
                            Margin="20,0,20,32"
                            Padding="28,28,28,32">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="20">

                            <Label Text="Bao gồm"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#1d1d1f"
                                   CharacterSpacing="0.5"/>

                            <Grid ColumnDefinitions="28,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
                                <Label Grid.Row="0" Grid.Column="0" Text="✓"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#0066cc" VerticalOptions="Start"/>
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="Bản thuyết minh giọng đọc gốc, chất lượng phòng thu"
                                       FontSize="15" TextColor="#1d1d1f"
                                       LineHeight="1.47"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="✓"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#0066cc" VerticalOptions="Start"/>
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="Câu chuyện sinh học chi tiết — sinh cảnh, hành vi, lịch sử"
                                       FontSize="15" TextColor="#1d1d1f"
                                       LineHeight="1.47"/>

                                <Label Grid.Row="2" Grid.Column="0" Text="✓"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#0066cc" VerticalOptions="Start"/>
                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="Thanh toán an toàn qua MoMo · Bảo mật mã hoá"
                                       FontSize="15" TextColor="#1d1d1f"
                                       LineHeight="1.47"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Action buttons (Apple pill — 52 height, full pill radius) -->
                    <VerticalStackLayout Padding="20,0" Spacing="12">
                        <Button Text="Mở khoá nội dung"
                                Clicked="OnUnlockClicked"
                                BackgroundColor="#0066cc"
                                TextColor="White"
                                FontSize="17"
                                HeightRequest="52"
                                CornerRadius="26"
                                BorderWidth="0"/>

                        <Button Text="Quay lại"
                                Clicked="OnBackClicked"
                                BackgroundColor="Transparent"
                                TextColor="#0066cc"
                                FontSize="17"
                                HeightRequest="52"
                                BorderColor="Transparent"
                                BorderWidth="0"/>
                    </VerticalStackLayout>

                    <!-- Footer fine-print -->
                    <Label HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Margin="40,32,40,0"
                           FontSize="11"
                           TextColor="#7a7a7a"
                           LineHeight="1.5"
                           CharacterSpacing="0.3"
                           Text="Thanh toán bảo mật qua MoMo Wallet · Sau khi mở khoá, bạn có thể truy cập nội dung này không giới hạn."/>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Top-right close (Apple translucent chip 36×36) -->
            <Border WidthRequest="36" HeightRequest="36"
                    BackgroundColor="#D2D2D7"
                    Opacity="0.85"
                    StrokeThickness="0"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,52,20,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                </Border.GestureRecognizers>
                <Label Text="✕"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#1d1d1f"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
  