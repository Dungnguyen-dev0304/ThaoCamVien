<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.StoryAudioPage"
             BackgroundColor="#F4F7F4"
             Title="Thuyết minh">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="20,50,20,30" Spacing="20">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto, *, Auto">
                <ImageButton Grid.Column="0"
                             Source="icon_back_dark.png"
                             WidthRequest="40" HeightRequest="40"
                             BackgroundColor="Transparent"
                             Clicked="OnBackClicked"/>
                <Label Grid.Column="1"
                       Text="ĐANG PHÁT"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       FontSize="12" FontAttributes="Bold"
                       TextColor="#757575" CharacterSpacing="2"/>
                <ImageButton Grid.Column="2"
                             Source="icon_menu_dots.png"
                             WidthRequest="40" HeightRequest="40"
                             BackgroundColor="Transparent"/>
            </Grid>

            <!-- Ảnh thumbnail POI -->
            <Border HeightRequest="300"
                    BackgroundColor="#E0E0E0"
                    Padding="0" Margin="10,10"
                    Stroke="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,15" Radius="25" Opacity="0.15"/>
                </Border.Shadow>
                <Image x:Name="PoiImage"
                       Source="placeholder_animal.png"
                       Aspect="AspectFill"/>
            </Border>

            <!-- Tên và thông tin POI -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" Margin="0,5,0,0">
                <Label x:Name="PoiNameLabel"
                       Text="Đang tải..."
                       FontSize="26" FontAttributes="Bold"
                       TextColor="#1C1C1E"
                       HorizontalOptions="Center"/>
                <Label x:Name="PoiSubtitleLabel"
                       Text="Thảo Cầm Viên Sài Gòn"
                       FontSize="14" TextColor="#2E7D32"
                       HorizontalOptions="Center" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <!-- Loading indicator khi stream audio -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#4CAF50"
                               HorizontalOptions="Center"/>

            <!-- Thanh tiến trình audio -->
            <VerticalStackLayout Spacing="4" Margin="5,10,5,0">
                <Slider x:Name="ProgressSlider"
                        Minimum="0" Maximum="100" Value="0"
                        MinimumTrackColor="#2E7D32"
                        MaximumTrackColor="#D7CCC8"
                        ThumbColor="#4CAF50"
                        DragCompleted="OnSliderDragCompleted"/>
                <Grid ColumnDefinitions="*, *">
                    <Label x:Name="CurrentTimeLabel"
                           Grid.Column="0" Text="00:00"
                           FontSize="13" TextColor="#757575"
                           HorizontalOptions="Start"/>
                    <Label x:Name="TotalTimeLabel"
                           Grid.Column="1" Text="00:00"
                           FontSize="13" TextColor="#757575"
                           HorizontalOptions="End"/>
                </Grid>
            </VerticalStackLayout>

            <!-- Nút điều khiển: Rewind | Play/Pause | Forward -->
            <Grid ColumnDefinitions="*, Auto, *"
                  HorizontalOptions="Fill" VerticalOptions="Center" Margin="0,10">

                <!-- Rewind 10s -->
                <ImageButton Grid.Column="0"
                             Source="icon_rewind.png"
                             WidthRequest="48" HeightRequest="48"
                             BackgroundColor="Transparent"
                             HorizontalOptions="End" Margin="0,0,20,0"
                             Clicked="OnRewindClicked"/>

                <!-- Play / Pause button -->
                <Border Grid.Column="1"
                        HeightRequest="86" WidthRequest="86"
                        BackgroundColor="#4CAF50"
                        Stroke="Transparent" Padding="0"
                        HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="43"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#2E7D32" Offset="0,8" Radius="15" Opacity="0.4"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPlayPauseClicked"/>
                    </Border.GestureRecognizers>
                    <Image x:Name="PlayPauseIcon"
                           Source="icon_play_white.png"
                           Aspect="AspectFit" Margin="22"/>
                </Border>

                <!-- Forward 10s -->
                <ImageButton Grid.Column="2"
                             Source="icon_forward.png"
                             WidthRequest="48" HeightRequest="48"
                             BackgroundColor="Transparent"
                             HorizontalOptions="Start" Margin="20,0,0,0"
                             Clicked="OnForwardClicked"/>
            </Grid>

            <!-- Mô tả POI -->
            <Border BackgroundColor="White" Padding="22"
                    Margin="0,15,0,0" Stroke="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,5" Radius="12" Opacity="0.06"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="PoiDescTitleLabel"
                           Text="Giới thiệu"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#1C1C1E"/>
                    <Label x:Name="PoiDescLabel"
                           Text="Đang tải thông tin..."
                           FontSize="15" TextColor="#424242"
                           LineHeight="1.5"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
