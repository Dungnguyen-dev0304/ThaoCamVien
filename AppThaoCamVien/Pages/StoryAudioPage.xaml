<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.StoryAudioPage"
             BackgroundColor="#061F14" 
             NavigationPage.HasNavigationBar="False">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Padding="20,50,20,40" Spacing="20">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto, *, Auto">
                <ImageButton Grid.Column="0" Source="icon_back_white.png" WidthRequest="32" HeightRequest="32" BackgroundColor="Transparent" Clicked="OnBackClicked"/>
                <Label Grid.Column="1" Text="Thảo Cầm Viên" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" FontAttributes="Bold" TextColor="White" CharacterSpacing="1"/>
                <ImageButton Grid.Column="2" Source="icon_menu_dots_white.png" WidthRequest="32" HeightRequest="32" BackgroundColor="Transparent"/>
            </Grid>

            <!-- Ảnh Thumbnail Vuông (Giống ảnh mẫu) -->
            <Border WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" Stroke="Transparent" Margin="0,10,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,10" Radius="20" Opacity="0.4"/>
                </Border.Shadow>
                <Image x:Name="PoiImage" Source="placeholder_animal.png" Aspect="AspectFill"/>
            </Border>

            <!-- Tên Loài & Danh pháp -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label x:Name="PoiNameLabel" Text="Hổ Đông Dương" FontSize="24" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                <Label x:Name="PoiSubtitleLabel" Text="Panthera tigris corbetti" FontSize="13" TextColor="#A0C8B4" FontAttributes="Italic" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Badges (Nhãn) -->
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Border BackgroundColor="#D32F2F" Padding="12,4" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Nguy cấp" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                </Border>
                <Border BackgroundColor="#1E88E5" Padding="12,4" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Thú ăn thịt" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                </Border>
                <Border BackgroundColor="#2E7D32" Padding="12,4" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="Động vật" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                </Border>
            </HorizontalStackLayout>

            <!-- Mô tả ngắn -->
            <Label x:Name="ShortIntroLabel" Text="Hổ Đông Dương là phân loài hổ đặc hữu, biểu tượng sức mạnh và di sản thiên nhiên quý giá của Đông Nam Á." FontSize="13" TextColor="White" Opacity="0.9" HorizontalTextAlignment="Center" LineHeight="1.4" Margin="0,10"/>

            <!-- Grid 4 Ô Thông số (Giống ảnh mẫu) -->
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#0A2A1B" Padding="16,12" Stroke="#15402A" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="200" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Cá thể" FontSize="12" TextColor="#A0C8B4" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#0A2A1B" Padding="16,12" Stroke="#15402A" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="15-20 năm" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Tuổi thọ" FontSize="12" TextColor="#A0C8B4" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#0A2A1B" Padding="16,12" Stroke="#15402A" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="150-195kg" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Cân nặng" FontSize="12" TextColor="#A0C8B4" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#0A2A1B" Padding="16,12" Stroke="#15402A" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label Text="Đông Nam Á" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Vùng phân bố" FontSize="12" TextColor="#A0C8B4" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- TRÌNH PHÁT AUDIO (Được lồng ghép tinh tế vào giao diện) -->
            <Border BackgroundColor="#0F3824" Padding="16" Margin="0,10,0,0" Stroke="#15402A" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">

                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#FFCA28" HorizontalOptions="Center" HeightRequest="20"/>

                    <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center" ColumnSpacing="15">
                        <!-- Play/Pause Button -->
                        <Border Grid.Column="0" HeightRequest="50" WidthRequest="50" BackgroundColor="#FFCA28" Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="25"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPlayPauseClicked"/>
                            </Border.GestureRecognizers>
                            <Image x:Name="PlayPauseIcon" Source="icon_play_dark.png" Aspect="AspectFit" Margin="14"/>
                        </Border>

                        <!-- Slider & Time -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="0" MinimumTrackColor="#FFCA28" MaximumTrackColor="#2A5C41" ThumbColor="#FFCA28" DragCompleted="OnSliderDragCompleted" Margin="0,-5,0,-5"/>
                            <Grid ColumnDefinitions="*, *">
                                <Label x:Name="CurrentTimeLabel" Grid.Column="0" Text="00:00" FontSize="11" TextColor="#A0C8B4" HorizontalOptions="Start"/>
                                <Label x:Name="TotalTimeLabel" Grid.Column="1" Text="00:00" FontSize="11" TextColor="#A0C8B4" HorizontalOptions="End"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Tabs -->
            <Grid ColumnDefinitions="*, *, *" Margin="0,10,0,0">
                <Label Grid.Column="0" Text="{DynamicResource TxtInfo}" TextColor="White" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Grid.Column="1" Text="{DynamicResource TxtImages}" TextColor="#689F82" FontSize="14" HorizontalOptions="Center"/>
                <Label Grid.Column="2" Text="{DynamicResource TxtMap}" TextColor="#689F82" FontSize="14" HorizontalOptions="Center"/>
            </Grid>
            <BoxView HeightRequest="2" BackgroundColor="#FFCA28" WidthRequest="80" HorizontalOptions="Start" Margin="20,0,0,0"/>

            <!-- Thẻ Vị trí Bản đồ (Giống ảnh mẫu) -->
            <Border BackgroundColor="#0A2A1B" Padding="16" Stroke="#15402A" StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <Label Text="📍" FontSize="20" VerticalOptions="Center"/>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Vị trí chuồng nuôi" FontSize="13" TextColor="White" FontAttributes="Bold"/>
                        <Label Text="Khu vực Thú Dữ - Điểm dừng số 4" FontSize="12" TextColor="#A0C8B4"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- Câu chuyện loài (Nội dung chi tiết) -->
            <VerticalStackLayout Spacing="10">
                <Label x:Name="PoiDescTitleLabel" Text="Câu chuyện loài" FontSize="16" FontAttributes="Bold" TextColor="White"/>
                <Label x:Name="PoiDescLabel" Text="Đang tải thông tin..." FontSize="14" TextColor="#D0E8DB" LineHeight="1.6"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>