<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.StoryAudioPage"
             BackgroundColor="White" 
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Color x:Key="BrandGreen">#28A745</Color>
        <Color x:Key="TextMain">#1A1A1A</Color>
        <Color x:Key="TextGray">#6C757D</Color>
        <Color x:Key="BorderLight">#E9ECEF</Color>
    </ContentPage.Resources>

    <Grid>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid RowDefinitions="400, Auto">

                <Image Grid.Row="0" x:Name="PoiImage" Source="placeholder_animal.png" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill" />

                <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Margin="0,-40,0,0" Padding="25,30,25,40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="35,35,0,0" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">
                        <BoxView HeightRequest="5" WidthRequest="40" Color="{StaticResource BorderLight}" CornerRadius="2.5" HorizontalOptions="Center" Margin="0,-15,0,10" />

                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label x:Name="PoiNameLabel" Text="Hổ Đông Dương" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextMain}" />
                                <Label x:Name="PoiSubtitleLabel" Text="Panthera tigris corbetti" FontSize="13" TextColor="{StaticResource TextGray}" FontAttributes="Italic" Margin="0,2,0,0"/>
                            </VerticalStackLayout>

                            <Border Grid.Column="1" BackgroundColor="#E8F5E9" Padding="12,6" StrokeThickness="0" VerticalOptions="Start" Margin="10,0,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="📍" FontSize="12" />
                                    <Label Text="Khu A1" FontSize="12" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                        <HorizontalStackLayout Spacing="10">
                            <Border BackgroundColor="#F8F9FA" Padding="12,6" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label Text="Thú ăn thịt" FontSize="12" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold"/>
                            </Border>
                            <Border BackgroundColor="#F8F9FA" Padding="12,6" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label Text="Đang bảo tồn" FontSize="12" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold"/>
                            </Border>
                            <Border BackgroundColor="#F8F9FA" Padding="12,6" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Label Text="Nguy cấp" FontSize="12" TextColor="{StaticResource BrandGreen}" FontAttributes="Bold"/>
                            </Border>
                        </HorizontalStackLayout>

                        <Border BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="{StaticResource BorderLight}" Padding="20" Margin="0,15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.05" Radius="15" Offset="0,5" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="20">
                                <VerticalStackLayout Grid.Column="0" Spacing="5" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="🔊" FontSize="16" TextColor="{StaticResource TextGray}" />
                                        <Label Text="THUYẾT MINH TỰ ĐỘNG" FontSize="13" TextColor="{StaticResource TextGray}" FontAttributes="Bold" />
                                    </HorizontalStackLayout>

                                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="{StaticResource BrandGreen}" HeightRequest="20"/>

                                    <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="0" MinimumTrackColor="{StaticResource BrandGreen}" MaximumTrackColor="{StaticResource BorderLight}" ThumbColor="{StaticResource BrandGreen}" DragCompleted="OnSliderDragCompleted" Margin="0,5"/>
                                    <Grid ColumnDefinitions="*, *">
                                        <Label x:Name="CurrentTimeLabel" Grid.Column="0" Text="00:00" FontSize="11" TextColor="{StaticResource TextGray}" FontAttributes="Bold" HorizontalOptions="Start"/>
                                        <Label x:Name="TotalTimeLabel" Grid.Column="1" Text="00:00" FontSize="11" TextColor="{StaticResource TextGray}" FontAttributes="Bold" HorizontalOptions="End"/>
                                    </Grid>
                                </VerticalStackLayout>

                                <Border Grid.Column="1" WidthRequest="65" HeightRequest="65" BackgroundColor="{StaticResource BrandGreen}" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="32.5" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="{StaticResource BrandGreen}" Offset="0,5" Radius="15" Opacity="0.4" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayPauseClicked" />
                                    </Border.GestureRecognizers>
                                    <Image x:Name="PlayPauseIcon" Source="icon_play_white.png" Aspect="AspectFit" Margin="20" />
                                </Border>
                            </Grid>
                        </Border>

                        <Label Text="Giới thiệu" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextMain}" Margin="0,5" />

                        <Label x:Name="ShortIntroLabel" FontSize="15" TextColor="{StaticResource TextGray}" LineHeight="1.6" Margin="0,0,0,10"/>

                        <Label x:Name="PoiDescTitleLabel" Text="Chi tiết sinh học" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextMain}" IsVisible="False"/>
                        <Label x:Name="PoiDescLabel" FontSize="14" TextColor="{StaticResource TextGray}" LineHeight="1.6"/>

                        <Button Text="Chỉ đường đến điểm này"
                                Clicked="OnNavigateToPoiClicked"
                                BackgroundColor="#111625"
                                TextColor="White"
                                CornerRadius="15"
                                HeightRequest="55"
                                FontAttributes="Bold"
                                Margin="0,20,0,30" />

                        <VerticalStackLayout Spacing="15" Opacity="0.5">
                            <Label Text="Thông số sinh học (Dữ liệu bổ sung)" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextGray}"/>
                            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="12">
                                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#F8F9FA" Padding="15" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout HorizontalOptions="Center">
                                        <Label Text="200" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextMain}" HorizontalOptions="Center"/>
                                        <Label Text="Cá thể" FontSize="12" TextColor="{StaticResource TextGray}" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#F8F9FA" Padding="15" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout HorizontalOptions="Center">
                                        <Label Text="15-20 năm" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextMain}" HorizontalOptions="Center"/>
                                        <Label Text="Tuổi thọ" FontSize="12" TextColor="{StaticResource TextGray}" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#F8F9FA" Padding="15" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout HorizontalOptions="Center">
                                        <Label Text="150-195kg" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextMain}" HorizontalOptions="Center"/>
                                        <Label Text="Cân nặng" FontSize="12" TextColor="{StaticResource TextGray}" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#F8F9FA" Padding="15" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <VerticalStackLayout HorizontalOptions="Center">
                                        <Label Text="Đông Nam Á" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource TextMain}" HorizontalOptions="Center"/>
                                        <Label Text="Phân bố" FontSize="12" TextColor="{StaticResource TextGray}" HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <controls:StateContainer State="{Binding State}" EmptyMessage="{Binding EmptyMessage}" ErrorMessage="{Binding ErrorMessage}" RetryCommand="{Binding RetryCommand}">
                                <controls:StateContainer.SuccessContent>
                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="{DynamicResource TxtVoice}" TextColor="{StaticResource TextMain}" FontSize="14" FontAttributes="Bold" />
                                        <CollectionView ItemsSource="{Binding Voices}" SelectionMode="None" HeightRequest="80" HorizontalScrollBarVisibility="Never">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout Orientation="Vertical" />
                                            </CollectionView.ItemsLayout>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BackgroundColor="#F8F9FA" Padding="10,8" StrokeThickness="0" Margin="0,0,0,5">
                                                        <Border.StrokeShape>
                                                            <RoundRectangle CornerRadius="12" />
                                                        </Border.StrokeShape>
                                                        <Label Text="{Binding DisplayName}" TextColor="{StaticResource TextMain}" FontSize="12" LineBreakMode="TailTruncation" />
                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>

                                        <Label Text="{DynamicResource TxtLyrics}" TextColor="{StaticResource TextMain}" FontSize="14" FontAttributes="Bold" />
                                        <CollectionView ItemsSource="{Binding Lyrics}" SelectionMode="None" HeightRequest="120">
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Label Text="{Binding Text}" TextColor="{StaticResource TextGray}" FontSize="13" LineBreakMode="TailTruncation" Margin="0,4,0,0" />
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </controls:StateContainer.SuccessContent>
                            </controls:StateContainer>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <Border WidthRequest="45" HeightRequest="45" BackgroundColor="#80000000" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Start" Margin="20,50">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22.5" />
            </Border.StrokeShape>
            <ImageButton Source="icon_back_white.png" WidthRequest="20" HeightRequest="20" BackgroundColor="Transparent" Clicked="OnBackClicked" />
        </Border>

    </Grid>
</ContentPage>