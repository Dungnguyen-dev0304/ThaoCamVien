<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.StoryAudioPage"
             BackgroundColor="White" 
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Color x:Key="BrandGreen">#28A745</Color>
        <Color x:Key="TextMain">#1A1A1A</Color>
        <Color x:Key="TextGray">#6C757D</Color>
        <Color x:Key="BorderLight">#E9ECEF</Color>
    </ContentPage.Resources>

    <Grid>

        <ScrollView VerticalScrollBarVisibility="Never">
            <Grid RowDefinitions="400, Auto">

                <Image Grid.Row="0" x:Name="PoiImage" Source="placeholder_animal.png" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill" />

                <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Margin="0,-40,0,0" Padding="25,30,25,40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="35,35,0,0" />
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="20">
                        <BoxView HeightRequest="5" WidthRequest="40" Color="{StaticResource BorderLight}" CornerRadius="2.5" HorizontalOptions="Center" Margin="0,-15,0,10" />

                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label x:Name="PoiNameLabel" Text="Hổ Đông Dương" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource TextMain}" />
                                <Label x:Name="PoiSubtitleLabel" Text="Panthera tigris corbetti" FontSize="13" TextColor="{StaticResource TextGray}" FontAttributes="Italic" Margin="0,2,0,0"/>
                            </VerticalStackLayout>
                        </Grid>
                        

                        <Border BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="{StaticResource BorderLight}" Padding="20" Margin="0,15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            

                            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="25">
                                <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="🔊" FontSize="16" TextColor="#6C757D" VerticalOptions="Center" />
                                        <Label Text="{DynamicResource TxtAutomatic}" FontSize="13" TextColor="#6C757D" FontAttributes="Bold" VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="{StaticResource BrandGreen}" HeightRequest="20"/>

                                    <Slider x:Name="ProgressSlider" 
                                            Minimum="0" Maximum="100" Value="30" 
                                            MinimumTrackColor="#3FA34D" 
                                            MaximumTrackColor="#E0E5E0" 
                                            ThumbColor="Transparent" 
                                            DragCompleted="OnSliderDragCompleted" 
                                            Margin="0,5,0,0"/>

                                    <Grid ColumnDefinitions="*, *">
                                        <Label x:Name="CurrentTimeLabel" Grid.Column="0" Text="01:12" FontSize="12" TextColor="#4A5568" FontAttributes="Bold" HorizontalOptions="Start"/>
                                        <Label x:Name="TotalTimeLabel" Grid.Column="1" Text="03:45" FontSize="12" TextColor="#4A5568" FontAttributes="Bold" HorizontalOptions="End"/>
                                    </Grid>

                                    <!-- Queue UX: khi user di chuyển sang POI khác trong lúc đang phát -->
                                    <Border x:Name="QueueHintPanel"
                                            IsVisible="False"
                                            BackgroundColor="#EEF6FF"
                                            StrokeThickness="1"
                                            Stroke="#D6E8FF"
                                            Padding="12,10"
                                            Margin="0,8,0,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                <Label Text="Tiếp theo" FontSize="11" TextColor="#2F5D9B" FontAttributes="Bold" />
                                                <Label x:Name="QueueNextPoiLabel"
                                                       Text="—"
                                                       FontSize="13"
                                                       TextColor="#1A1A1A"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                            </VerticalStackLayout>

                                            <Border Grid.Column="1"
                                                    x:Name="QueueSkipBtn"
                                                    BackgroundColor="#1E5631"
                                                    Padding="12,8"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnQueueSkipTapped" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                    <Label Text="Skip" TextColor="White" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                                                    <Label Text="⏭" TextColor="White" FontSize="12" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>

                                <Border Grid.Column="1" WidthRequest="65" HeightRequest="65" BackgroundColor="#1E5631" StrokeThickness="0" VerticalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="32.5" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#1E5631" Offset="0,4" Radius="10" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPlayPauseClicked" />
                                    </Border.GestureRecognizers>

                                    <Image x:Name="PlayPauseIcon" Source="icon_play_white.png" Aspect="AspectFit" Margin="22,20,18,20" />
                                </Border>
                            </Grid>
                        </Border>

                        <Label Text="{DynamicResource TxtAboutApp}" FontSize="30" FontAttributes="Bold" TextColor="{StaticResource TextMain}" Margin="1" />

                        <!-- <Label x:Name="ShortIntroLabel" FontSize="15" TextColor="{StaticResource TextGray}" LineHeight="1.6" Margin="0,0,0,10"/> -->

                        <Label x:Name="PoiDescTitleLabel" Text="Chi tiết sinh học" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextMain}" IsVisible="False"/>
                        <Label x:Name="PoiDescLabel" FontSize="14" TextColor="{StaticResource TextGray}" LineHeight="1.6"/>

                        <Button Text="{DynamicResource TxtDirections}"
                                Clicked="OnNavigateToPoiClicked"
                                BackgroundColor="#111625"
                                TextColor="White"
                                CornerRadius="15"
                                HeightRequest="55"
                                FontAttributes="Bold"
                                Margin="0,20,0,30" />

                    </VerticalStackLayout>
                </Border>
            </Grid>
        </ScrollView>

        <Border WidthRequest="45" HeightRequest="45" BackgroundColor="#80000000" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Start" Margin="20,50">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22.5" />
            </Border.StrokeShape>
            <ImageButton Source="icon_back_white.png" WidthRequest="20" HeightRequest="20" BackgroundColor="Transparent" Clicked="OnBackClicked" />
        </Border>

    </Grid>
</ContentPage>
  