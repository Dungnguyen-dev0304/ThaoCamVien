<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Pages.QrPage"
             Title="Quét mã QR"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <Grid>
        <BoxView Color="#1C1C1E" Opacity="0.8" />

        <ImageButton Source="icon_back_white.png" WidthRequest="40" HeightRequest="40" 
                     VerticalOptions="Start" HorizontalOptions="Start" Margin="20,40,0,0" 
                     BackgroundColor="Transparent" />

        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="25">
            <Label Text="Quét mã tại chuồng thú" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="Khung hình sẽ tự động nhận diện mã QR" TextColor="#B0BEC5" FontSize="14" HorizontalOptions="Center" Margin="0,-15,0,0"/>

            <Border WidthRequest="260" HeightRequest="260" BackgroundColor="Transparent" 
                    Stroke="#4CAF50" StrokeThickness="2" Padding="0" Margin="0,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#4CAF50" Offset="0,0" Radius="20" Opacity="0.6"/>
                </Border.Shadow>

                <BoxView Color="#4CAF50" HeightRequest="2" WidthRequest="260" Opacity="0.5" 
                         VerticalOptions="Center" HorizontalOptions="Center" />
            </Border>
        </VerticalStackLayout>

        <Grid VerticalOptions="End" Margin="0,0,0,50" ColumnDefinitions="*,*" Padding="30,0">
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="8">
                <Border HeightRequest="64" WidthRequest="64" BackgroundColor="#2C2C2E" Stroke="Transparent" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32" />
                    </Border.StrokeShape>
                    <Image Source="icon_flash.png" Aspect="AspectFit"/>
                </Border>
                <Label Text="Bật đèn" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="8">
                <Border HeightRequest="64" WidthRequest="64" BackgroundColor="#4CAF50" Stroke="Transparent" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#4CAF50" Offset="0,4" Radius="10" Opacity="0.5"/>
                    </Border.Shadow>
                    <Image Source="numpad_white.png" Aspect="AspectFit" />
                </Border>
                <Label Text="Nhập mã tay" TextColor="White" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>