<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:controls="clr-namespace:AppThaoCamVien.Controls"
             x:Class="AppThaoCamVien.Pages.QrPage"
             BackgroundColor="#1C1C1E"
             Title="{DynamicResource TxtQrTitle}">

    <Grid>
        <zxing:CameraBarcodeReaderView x:Name="BarcodeReader"
            IsDetecting="True"
            CameraLocation="Rear"
            BarcodesDetected="OnBarcodesDetected"
            HorizontalOptions="Fill" VerticalOptions="Fill">
            <zxing:CameraBarcodeReaderView.Options>
                <zxing:BarcodeReaderOptions
                    Formats="QrCode"
                    AutoRotate="True"
                    Multiple="False"
                    TryHarder="True" />
            </zxing:CameraBarcodeReaderView.Options>
        </zxing:CameraBarcodeReaderView>

        <BoxView Color="#1C1C1E" Opacity="0.6" HorizontalOptions="Fill" VerticalOptions="Fill"/>

        <!-- Header -->
        <Grid VerticalOptions="Start" Padding="20,50,20,0" ColumnDefinitions="Auto, *, Auto">
            <ImageButton Grid.Column="0" Source="icon_back_white.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent" Clicked="OnBackClicked"/>
            <!-- Tiêu đề đổi theo ngôn ngữ -->
            <Label Grid.Column="1" Text="{DynamicResource TxtQrTitle}"
                   TextColor="White" FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- Viewfinder -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <!-- Hướng dẫn đổi theo ngôn ngữ -->
            <Label Text="{DynamicResource TxtQrInstruction}" TextColor="#B0BEC5"
                   FontSize="14" HorizontalOptions="Center"/>

            <Border x:Name="ScanFrame" WidthRequest="260" HeightRequest="260"
                    BackgroundColor="Transparent" Stroke="#4CAF50" StrokeThickness="3" Padding="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#4CAF50" Offset="0,0" Radius="25" Opacity="0.7"/>
                </Border.Shadow>
                <BoxView x:Name="ScanLine" Color="#4CAF50" HeightRequest="3"
                         WidthRequest="240" Opacity="0.8"
                         VerticalOptions="Start" HorizontalOptions="Center" Margin="0,10"/>
            </Border>

            <!-- State: searching / loading / empty / error (API-first) -->
            <controls:StateContainer State="{Binding State}"
                                      EmptyMessage="{Binding EmptyMessage}"
                                      ErrorMessage="{Binding ErrorMessage}"
                                      RetryCommand="{Binding RetryCommand}">
                <controls:StateContainer.SuccessContent>
                    <Label Text="{DynamicResource TxtQrSearching}"
                           TextColor="#B0BEC5" FontSize="13" HorizontalOptions="Center" />
                </controls:StateContainer.SuccessContent>
            </controls:StateContainer>
        </VerticalStackLayout>

        <!-- Bottom controls -->
        <Grid VerticalOptions="End" Margin="0,0,0,60" ColumnDefinitions="*,*" Padding="40,0">

            <!-- Flash -->
            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="10">
                <Border x:Name="FlashButton" HeightRequest="64" WidthRequest="64"
                        BackgroundColor="#2C2C2E" Stroke="Transparent" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleFlash"/>
                    </Border.GestureRecognizers>
                    <Image x:Name="FlashIcon" Source="icon_flash.png" Aspect="AspectFit"/>
                </Border>
                <!-- Label flash đổi theo ngôn ngữ -->
                <Label Text="{DynamicResource TxtFlash}" TextColor="White" FontSize="13"
                       FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Nhập mã tay -->
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="10">
                <Border HeightRequest="64" WidthRequest="64" BackgroundColor="#4CAF50"
                        Stroke="Transparent" Padding="16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#4CAF50" Offset="0,4" Radius="10" Opacity="0.5"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOpenNumpad"/>
                    </Border.GestureRecognizers>
                    <Image Source="numpad_white.png" Aspect="AspectFit"/>
                </Border>
                <!-- Label nhập mã đổi theo ngôn ngữ -->
                <Label Text="{DynamicResource TxtManualCode}" TextColor="White" FontSize="13"
                       FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
