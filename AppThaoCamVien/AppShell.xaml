<?xml version="1.0" encoding="utf-8" ?>
<!--
    ⚠️ QUAN TRỌNG:
    Shell dùng DataTemplate sẽ KHÔNG inject được DI constructor.
    Giải pháp: Dùng ShellContent với x:TypeArguments hoặc dùng
    ServiceProvider factory trong code-behind.
    
    Cách đơn giản nhất: Các page có DI (MapPage) → navigate thủ công từ code.
    Các page đơn giản (QrPage, NumpadPage, StoryAudioPage) → dùng Shell route.
-->
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:AppThaoCamVien.Pages"
       xmlns:views="clr-namespace:AppThaoCamVien.Views"
       x:Class="AppThaoCamVien.AppShell">
    
<!--  Đây là phần 3 chấm ngang cũ
    <Shell.FlyoutBackground>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#89d957" Offset="0.1"/>
            <GradientStop Color="#c9e265" Offset="1.0"/>
        </LinearGradientBrush>
    </Shell.FlyoutBackground> 

    
    <Shell.FlyoutHeader>
        <views:FlyoutHeaderView/>
    </Shell.FlyoutHeader>

    <Shell.FlyoutFooter>
        <views:FlyoutFooterView/>
