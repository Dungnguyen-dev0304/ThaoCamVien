    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid ColumnDefinitions="0.25*,0.75*" Padding="0,10">
                <Image Source="{Binding FlyoutIcon}"
                       HeightRequest="40" HorizontalOptions="Center"/>
                <Label Grid.Column="1"
                       TextColor="White"
                       Text="{Binding Title}"
                       FontSize="Small" FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate> -->

    <!-- Trang chủ: HomePage (dùng factory trong AppShell.xaml.cs) -->
    <FlyoutItem Title="Trang chủ" Icon="menu_white.png" Route="home">
        <ShellContent x:Name="HomeShellContent"
                      Title="Trang chủ"
                      ContentTemplate="{DataTemplate pages:HomePage}"/>
    </FlyoutItem>

    <!-- Sơ đồ: MapPage được navigate thủ công từ HomePage vì cần DI -->
    <!-- QR và Numpad được register route bên dưới -->

    <FlyoutItem Title="Giới thiệu" Icon="about_white.png">
        <Shell.ItemTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="0.25*,0.75*" Padding="20,20">
                    <Image Source="{Binding FlyoutIcon}"
                           HeightRequest="50" HorizontalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="{Binding Title}"
                               TextColor="White" FontSize="Medium" FontAttributes="Bold"/>
                        <Label Text="Thông tin ứng dụng"
                               TextColor="White" FontSize="Small"/>
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </Shell.ItemTemplate>
        <ShellContent ContentTemplate="{DataTemplate pages:AboutPage}"/>
    </FlyoutItem>

</Shell>
