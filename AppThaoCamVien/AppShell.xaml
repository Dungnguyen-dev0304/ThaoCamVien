<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:AppThaoCamVien.Pages"
       x:Class="AppThaoCamVien.AppShell">

    <Shell.FlyoutBackground>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#89d957" Offset="0.1"/>
            <GradientStop Color="#c9e265" Offset="1.0"/>
        </LinearGradientBrush>
    </Shell.FlyoutBackground>

    <TabBar x:Name="Main">
        <Tab Title="{DynamicResource TabHome}" Icon="menu_white.png">
            <ShellContent ContentTemplate="{DataTemplate pages:HomePage}"/>
        </Tab>
        <Tab Title="{DynamicResource TabQR}" Icon="qr_white.png">
            <ShellContent ContentTemplate="{DataTemplate pages:QrPage}" />
        </Tab>
        <Tab Title="{DynamicResource TabNumpad}" Icon="numpad_white.png">
            <ShellContent ContentTemplate="{DataTemplate pages:NumpadPage}" />
        </Tab>
        <Tab Title="{DynamicResource TabStory}" Icon="story_white.png">
            <ShellContent ContentTemplate="{DataTemplate pages:AnimalListPage}" />
        </Tab>
        <Tab Title="{DynamicResource TabMap}" Icon="map_white.png">
            <ShellContent ContentTemplate="{DataTemplate pages:MapPage}" />
        </Tab>
    </TabBar>

    <FlyoutItem Title="{DynamicResource TabAbout}" Icon="about_white.png">
        <Shell.ItemTemplate>
            <DataTemplate>
                <Grid ColumnDefinitions="0.25*,0.75*" Padding="20,20">
                    <Image Source="{Binding FlyoutIcon}" HeightRequest="50" HorizontalOptions="Center"/>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                        <Label Text="{Binding Title}" TextColor="White" FontSize="Medium" FontAttributes="Bold"/>
                        <Label Text="{DynamicResource TxtAppInfo}" TextColor="White" FontSize="Small"/>
                    </VerticalStackLayout>
                </Grid>
            </DataTemplate>
        </Shell.ItemTemplate>
        <ShellContent ContentTemplate="{DataTemplate pages:AboutPage}"/>
    </FlyoutItem>

</Shell>