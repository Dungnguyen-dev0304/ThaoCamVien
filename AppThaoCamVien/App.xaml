<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppThaoCamVien.Pages"
             xmlns:views="clr-namespace:AppThaoCamVien.Views"
             x:Class="AppThaoCamVien.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.MainPage>
        <Shell >

            <Shell.FlyoutBackground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#89d957" Offset="0.1"/>
                    <GradientStop Color="#c9e265" Offset="1.0"/>
                </LinearGradientBrush>
            </Shell.FlyoutBackground>
            
            <!--
            <Shell.FlyoutHeader>
                <views:FlyoutHeaderView></views:FlyoutHeaderView>
            </Shell.FlyoutHeader>

            <Shell.FlyoutFooter>
                <views:FlyoutFooterView></views:FlyoutFooterView>
            </Shell.FlyoutFooter> -->

            <Shell.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="0.25*,0.75*" Padding="0,10">
                        <Image Source="{Binding FlyoutIcon}"
                               HeightRequest="45"
                               HorizontalOptions="Center"/>
                        <Label Grid.Column="1"
                               TextColor="White"
                               Text="{Binding Title}"
                               FontSize="Small"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </Shell.ItemTemplate>

            <TabBar x:Name="Main">
                <Tab Title="Trang chủ" Icon="menu_white.png" >
                    <ShellContent ContentTemplate="{DataTemplate local:HomePage}"/>
                </Tab>
                <Tab Title="QR" Icon="qr_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:QrPage}" />
                </Tab>
                <Tab Title="Số" Icon="numpad_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:NumpadPage}" />
                </Tab>
                <Tab Title="Câu chuyện" Icon="story_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:AnimalListPage}" />
                </Tab>
                <Tab Title="Sơ đồ" Icon="map_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:MapPage}" />
                </Tab>
            </TabBar>
        </Shell>
    </Application.MainPage>
</Application>