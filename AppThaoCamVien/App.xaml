<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppThaoCamVien.Pages"
             xmlns:views="clr-namespace:AppThaoCamVien.Views"
             x:Class="AppThaoCamVien.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.MainPage>
        <Shell FlyoutBehavior="Flyout" FlyoutHeaderBehavior="Fixed" FlyoutVerticalScrollMode="Auto">

            <Shell.FlyoutHeader>
                <views:FlyoutHeaderView></views:FlyoutHeaderView>
            </Shell.FlyoutHeader>

            <Shell.FlyoutFooter>
                <views:FlyoutFooterView></views:FlyoutFooterView>
            </Shell.FlyoutFooter>

            <Shell.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="0.25*,0.75*" Padding="0,10">
                        <Image Source="{Binding FlyoutIcon}"
                               HeightRequest="45"
                               HorizontalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding Title}"
                               FontSize="Small"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </Shell.ItemTemplate>

            <FlyoutItem Title="Trang chủ" Icon="menu_white.png">
                <Tab Title="QR" Icon="qr_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:QrPage}" />
                </Tab>
                <Tab Title="Số" Icon="numpad_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:NumpadPage}" />
                </Tab>
                <Tab Title="Câu chuyện" Icon="story_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:StoryAudioPage}" />
                </Tab>
                <Tab Title="Sơ đồ" Icon="map_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:MapPage}" />
                </Tab>
            </FlyoutItem>

            <FlyoutItem Title="Map Only" Icon="map_white.png">
                <ShellContent ContentTemplate="{DataTemplate local:MapPage}" />
            </FlyoutItem>

            <FlyoutItem Title="Home Extra" Icon="menu_white.png">
                <ShellContent ContentTemplate="{DataTemplate local:HomePage}" />
            </FlyoutItem>

        </Shell>
    </Application.MainPage>
</Application>