<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppThaoCamVien.Pages"
             x:Class="AppThaoCamVien.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.MainPage>
        <Shell>
            <TabBar x:Name="ThaoCamVienAPPPPP">
                <Tab Title="QR" Icon="qr_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:QrPage}"></ShellContent>
                </Tab>
                <Tab Title="Setting" Icon="numpad_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:NumpadPage}"></ShellContent>
                </Tab>
                <Tab Title="About" Icon="story_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:StoryAudioPage}"></ShellContent>
                </Tab>
                <Tab Title="About" Icon="map_white.png">
                    <ShellContent ContentTemplate="{DataTemplate local:MapPage}"></ShellContent>
                </Tab>
            </TabBar>
        </Shell>
    </Application.MainPage>
</Application>
