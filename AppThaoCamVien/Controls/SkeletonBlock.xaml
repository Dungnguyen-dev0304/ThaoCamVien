<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppThaoCamVien.Controls.SkeletonBlock"
             x:Name="Root">
    <Border x:Name="RootBorder"
            BackgroundColor="#E6E9E6"
            StrokeThickness="0"
            HeightRequest="{Binding SkeletonHeight, Source={x:Reference Root}}"
            WidthRequest="{Binding SkeletonWidth, Source={x:Reference Root}}">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="10" />
        </Border.StrokeShape>
    </Border>
</ContentView>
